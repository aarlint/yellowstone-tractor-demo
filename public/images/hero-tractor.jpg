0432 \u0441\u044a\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435 \u0441\u044a\u0441 \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u0430 \u0437\u0430 \u0434\u043e\u0441\u0442\u044a\u043f\u043d\u043e\u0441\u0442 \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003E\u0422\u043e\u0437\u0438 \u0446\u0435\u043b\u0435\u0432\u0438 \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442 \u043d\u0430\u0441\u043e\u0447\u0432\u0430 \u043d\u0430\u0448\u0438\u0442\u0435 \u0443\u0441\u0438\u043b\u0438\u044f \u0438 \u0442\u0435\u043a\u0443\u0449\u0438\u0442\u0435 \u043f\u043e\u0434\u043e\u0431\u0440\u0435\u043d\u0438\u044f \u0432 \u043e\u0431\u043b\u0430\u0441\u0442\u0442\u0430 \u043d\u0430 \u0434\u043e\u0441\u0442\u044a\u043f\u043d\u043e\u0441\u0442\u0442\u0430.\u003C/p\u003E\n\u003Ch2\u003E\u0422\u0435\u043a\u0443\u0449\u043e \u0441\u044a\u0441\u0442\u043e\u044f\u043d\u0438\u0435 \u043d\u0430 \u0441\u044a\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435\u0442\u043e\u003C/h2\u003E\n\u003Cp\u003E\u0412\u044a\u0437 \u043e\u0441\u043d\u043e\u0432\u0430 \u043d\u0430 \u043d\u0430\u0448\u0430\u0442\u0430 \u0432\u044a\u0442\u0440\u0435\u0448\u043d\u0430 \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0430 \u0442\u043e\u0437\u0438 \u0443\u0435\u0431\u0441\u0430\u0439\u0442 \u0435 \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E \u0441\u043f\u0440\u044f\u043c\u043e \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003E\u0422\u043e\u0432\u0430 \u0441\u044a\u0441\u0442\u043e\u044f\u043d\u0438\u0435 \u043e\u0442\u0440\u0430\u0437\u044f\u0432\u0430 \u043d\u0430\u0448\u0430\u0442\u0430 \u043e\u0446\u0435\u043d\u043a\u0430 \u043a\u044a\u043c \u043c\u043e\u043c\u0435\u043d\u0442\u0430 \u043d\u0430 \u043f\u0443\u0431\u043b\u0438\u043a\u0443\u0432\u0430\u043d\u0435 \u0438 \u0441\u0435 \u0431\u0430\u0437\u0438\u0440\u0430 \u043d\u0430 \u0432\u044a\u0442\u0440\u0435\u0448\u0435\u043d \u043f\u0440\u0435\u0433\u043b\u0435\u0434 \u0438 \u043d\u0430\u043b\u0438\u0447\u043d\u0430\u0442\u0430 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f. \u0414\u043e\u0441\u0442\u044a\u043f\u043d\u043e\u0441\u0442\u0442\u0430 \u0435 \u043d\u0435\u043f\u0440\u0435\u043a\u044a\u0441\u043d\u0430\u0442 \u043f\u0440\u043e\u0446\u0435\u0441 \u0438 \u043d\u0438\u0432\u0430\u0442\u0430 \u043d\u0430 \u0441\u044a\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435 \u043c\u043e\u0433\u0430\u0442 \u0434\u0430 \u0441\u0435 \u043f\u0440\u043e\u043c\u0435\u043d\u044f\u0442 \u043f\u0440\u0438 \u0432\u043d\u0435\u0434\u0440\u044f\u0432\u0430\u043d\u0435 \u043d\u0430 \u0430\u043a\u0442\u0443\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u0438.\u003C/p\u003E\n\u003Ch2\u003E\u0424\u0443\u043d\u043a\u0446\u0438\u0438 \u0437\u0430 \u0434\u043e\u0441\u0442\u044a\u043f\u043d\u043e\u0441\u0442\u003C/h2\u003E\n\u003Cp\u003E\u0417\u0430 \u0434\u0430 \u043f\u043e\u0434\u043f\u043e\u043c\u043e\u0433\u043d\u0435\u043c \u0434\u043e\u0441\u0442\u044a\u043f\u043d\u043e\u0441\u0442\u0442\u0430, \u0442\u043e\u0437\u0438 \u0443\u0435\u0431\u0441\u0430\u0439\u0442 \u0432\u043a\u043b\u044e\u0447\u0432\u0430 \u0438\u043d\u0442\u0435\u0440\u0444\u0435\u0439\u0441\u0430 \u0437\u0430 \u0434\u043e\u0441\u0442\u044a\u043f\u043d\u043e\u0441\u0442 AccessYes. \u0422\u043e\u0437\u0438 \u0438\u043d\u0442\u0435\u0440\u0444\u0435\u0439\u0441 \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0432\u0430 \u043d\u0430 \u043f\u043e\u0442\u0440\u0435\u0431\u0438\u0442\u0435\u043b\u0438\u0442\u0435 \u0434\u0430 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u0432\u0430\u0442 \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u0438 \u0432\u0438\u0437\u0443\u0430\u043b\u043d\u0438 \u0438 \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0430\u043b\u043d\u0438 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0438 \u0441\u043f\u043e\u0440\u0435\u0434 \u0438\u043d\u0434\u0438\u0432\u0438\u0434\u0443\u0430\u043b\u043d\u0438\u0442\u0435 \u043d\u0443\u0436\u0434\u0438, \u043a\u0430\u0442\u043e \u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003E\u0420\u0435\u0433\u0443\u043b\u0438\u0440\u0430\u043d\u0435 \u043d\u0430 \u0440\u0430\u0437\u043c\u0435\u0440\u0430 \u0438 \u0440\u0430\u0437\u0441\u0442\u043e\u044f\u043d\u0438\u044f\u0442\u0430 \u043d\u0430 \u0442\u0435\u043a\u0441\u0442\u0430\u003C/li\u003E\n\u003Cli\u003E\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 \u043d\u0430 \u043a\u043e\u043d\u0442\u0440\u0430\u0441\u0442\u0430 \u0438 \u0446\u0432\u0435\u0442\u043e\u0432\u0435\u0442\u0435\u003C/li\u003E\n\u003Cli\u003E\u0418\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u0438 \u0437\u0430 \u043f\u043e\u0434\u0447\u0435\u0440\u0442\u0430\u0432\u0430\u043d\u0435\u003C/li\u003E\n\u003Cli\u003E\u0414\u0440\u0443\u0433\u0438 \u043e\u043f\u0446\u0438\u0438 \u0437\u0430 \u043f\u043e\u0434\u043f\u043e\u043c\u043e\u0433\u043d\u0430\u0442\u043e \u0432\u0438\u0437\u0443\u0430\u043b\u0438\u0437\u0438\u0440\u0430\u043d\u0435\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003E\u0422\u0435\u0437\u0438 \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u0438 \u0441\u0430 \u043f\u0440\u0435\u0434\u043d\u0430\u0437\u043d\u0430\u0447\u0435\u043d\u0438 \u0434\u0430 \u043f\u043e\u0434\u043e\u0431\u0440\u044f\u0442 \u043f\u043e\u0442\u0440\u0435\u0431\u0438\u0442\u0435\u043b\u0441\u043a\u043e\u0442\u043e \u0438\u0437\u0436\u0438\u0432\u044f\u0432\u0430\u043d\u0435, \u043d\u043e \u043d\u0435 \u0437\u0430\u043c\u0435\u043d\u044f\u0442 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e\u0441\u0442\u0442\u0430 \u043e\u0442 \u0434\u043e\u0441\u0442\u044a\u043f\u043d\u043e \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435 \u0438 \u043a\u043e\u0440\u0435\u043a\u0442\u043d\u0430 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0430 \u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0430 \u043d\u0430 \u0443\u0435\u0431\u0441\u0430\u0439\u0442\u0430.\u003C/p\u003E\n\u003Ch2\u003E\u041e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u044f \u0438 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0438 \u0441\u044a\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u044f\u003C/h2\u003E\n\u003Cp\u003E\u041c\u043e\u043b\u044f, \u0438\u043c\u0430\u0439\u0442\u0435 \u043f\u0440\u0435\u0434\u0432\u0438\u0434 \u0441\u043b\u0435\u0434\u043d\u043e\u0442\u043e:\u003C/p\u003E\n\u003Cp\u003E\u041d\u0430\u043b\u0438\u0447\u0438\u0435\u0442\u043e \u0438 \u0435\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u0442\u0430 \u043d\u0430 \u0444\u0443\u043d\u043a\u0446\u0438\u0438\u0442\u0435 \u0437\u0430 \u0434\u043e\u0441\u0442\u044a\u043f\u043d\u043e\u0441\u0442 \u0437\u0430\u0432\u0438\u0441\u044f\u0442 \u043e\u0442 \u043a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044f\u0442\u0430 \u043d\u0430 \u0443\u0435\u0431\u0441\u0430\u0439\u0442\u0430 \u0438 \u043e\u0442 \u0442\u0435\u043a\u0443\u0449\u0430\u0442\u0430 \u043f\u043e\u0434\u0434\u0440\u044a\u0436\u043a\u0430.\u003C/p\u003E\n\u003Cp\u003E\u0412\u044a\u043f\u0440\u0435\u043a\u0438 \u0443\u0441\u0438\u043b\u0438\u044f\u0442\u0430 \u043d\u0438 \u0434\u0430 \u043e\u0441\u0438\u0433\u0443\u0440\u0438\u043c \u0434\u043e\u0441\u0442\u044a\u043f\u043d\u043e\u0441\u0442 \u0432 \u0440\u0430\u043c\u043a\u0438\u0442\u0435 \u043d\u0430 \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, \u0447\u0430\u0441\u0442 \u043e\u0442 \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435\u0442\u043e \u0438\u043b\u0438 \u0444\u0443\u043d\u043a\u0446\u0438\u0438\u0442\u0435 \u043c\u043e\u0436\u0435 \u0432\u0441\u0435 \u043e\u0449\u0435 \u0434\u0430 \u043d\u0435 \u043e\u0442\u0433\u043e\u0432\u0430\u0440\u044f\u0442 \u043d\u0430\u043f\u044a\u043b\u043d\u043e \u043d\u0430 \u0438\u0437\u0431\u0440\u0430\u043d\u0438\u0442\u0435 \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u0438 \u0437\u0430 \u0434\u043e\u0441\u0442\u044a\u043f\u043d\u043e\u0441\u0442. \u0427\u0430\u0441\u0442 \u043e\u0442 \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435\u0442\u043e \u043c\u043e\u0436\u0435 \u0434\u0430 \u0431\u044a\u0434\u0435 \u043f\u0440\u0435\u0434\u043e\u0441\u0442\u0430\u0432\u044f\u043d\u0430 \u043e\u0442 \u0442\u0440\u0435\u0442\u0438 \u0441\u0442\u0440\u0430\u043d\u0438 \u0438\u043b\u0438 \u0434\u0430 \u0435 \u043f\u043e\u0432\u043b\u0438\u044f\u043d\u0430 \u043e\u0442 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0438 \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u044f \u0438\u0437\u0432\u044a\u043d \u043d\u0430\u0448\u0438\u044f \u043d\u0435\u043f\u043e\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0435\u043d \u043a\u043e\u043d\u0442\u0440\u043e\u043b.\u003C/p\u003E\n\u003Cp\u003E\u041e\u0441\u0432\u0435\u043d \u0442\u043e\u0432\u0430 \u0435 \u0432\u044a\u0437\u043c\u043e\u0436\u043d\u043e \u0434\u0430 \u0438\u043c\u0430 \u043d\u0430\u0441\u043b\u0435\u0434\u0435\u043d\u043e \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435 \u0438\u043b\u0438 \u0438\u043d\u0442\u0435\u0433\u0440\u0430\u0446\u0438\u0438, \u043a\u043e\u0438\u0442\u043e \u0432\u0441\u0435 \u043e\u0449\u0435 \u043d\u0435 \u0441\u0430 \u043d\u0430\u043f\u044a\u043b\u043d\u043e \u0441\u044a\u043e\u0431\u0440\u0430\u0437\u0435\u043d\u0438 \u0441 \u0438\u0437\u0431\u0440\u0430\u043d\u0438\u044f \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442. \u0410\u043a\u0442\u0438\u0432\u043d\u043e \u0440\u0430\u0431\u043e\u0442\u0438\u043c \u0437\u0430 \u0438\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u0446\u0438\u0440\u0430\u043d\u0435 \u0438 \u043f\u0440\u0435\u043e\u0434\u043e\u043b\u044f\u0432\u0430\u043d\u0435 \u043d\u0430 \u0431\u0430\u0440\u0438\u0435\u0440\u0438 \u043f\u0440\u0435\u0434 \u0434\u043e\u0441\u0442\u044a\u043f\u043d\u043e\u0441\u0442\u0442\u0430, \u043a\u043e\u0438\u0442\u043e \u0441\u0430 \u043f\u043e\u0434 \u043d\u0430\u0448 \u043a\u043e\u043d\u0442\u0440\u043e\u043b.\u003C/p\u003E\n\u003Ch2\u003E\u041e\u0431\u0440\u0430\u0442\u043d\u0430 \u0432\u0440\u044a\u0437\u043a\u0430 \u0438 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u0438\u003C/h2\u003E\n\u003Cp\u003E\u0410\u043a\u043e \u0441\u0440\u0435\u0449\u043d\u0435\u0442\u0435 \u0437\u0430\u0442\u0440\u0443\u0434\u043d\u0435\u043d\u0438\u044f \u043f\u0440\u0438 \u0434\u043e\u0441\u0442\u044a\u043f\u0430 \u0434\u043e \u0441\u044a\u0434\u044a\u0440\u0436\u0430\u043d\u0438\u0435 \u043d\u0430 \u0442\u043e\u0437\u0438 \u0443\u0435\u0431\u0441\u0430\u0439\u0442 \u0438\u043b\u0438 \u0436\u0435\u043b\u0430\u0435\u0442\u0435 \u0434\u0430 \u0441\u044a\u043e\u0431\u0449\u0438\u0442\u0435 \u0437\u0430 \u043f\u0440\u043e\u0431\u043b\u0435\u043c \u0441 \u0434\u043e\u0441\u0442\u044a\u043f\u043d\u043e\u0441\u0442\u0442\u0430, \u0441\u0432\u044a\u0440\u0436\u0435\u0442\u0435 \u0441\u0435 \u0441 \u043d\u0430\u0441:\u003C/p\u003E\n\u003Cp\u003E\u0418\u043c\u0435\u0439\u043b: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003E\u041c\u043e\u043b\u044f, \u0432\u043a\u043b\u044e\u0447\u0435\u0442\u0435 \u043a\u043e\u043d\u043a\u0440\u0435\u0442\u043d\u0438\u044f URL \u0430\u0434\u0440\u0435\u0441 \u043d\u0430 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0430\u0442\u0430 \u0438 \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u043d\u0430 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0430, \u0437\u0430 \u0434\u0430 \u043c\u043e\u0436\u0435\u043c \u0434\u0430 \u0433\u043e \u043f\u0440\u043e\u0443\u0447\u0438\u043c \u0438 \u0434\u0430 \u0440\u0435\u0430\u0433\u0438\u0440\u0430\u043c\u0435 \u0430\u0434\u0435\u043a\u0432\u0430\u0442\u043d\u043e.\u003C/p\u003E\n\u003Ch2\u003E\u041d\u0435\u043f\u0440\u0435\u043a\u044a\u0441\u043d\u0430\u0442\u043e \u0443\u0441\u044a\u0432\u044a\u0440\u0448\u0435\u043d\u0441\u0442\u0432\u0430\u043d\u0435\u003C/h2\u003E\n\u003Cp\u003E\u0414\u043e\u0441\u0442\u044a\u043f\u043d\u043e\u0441\u0442\u0442\u0430 \u0435 \u043d\u0435\u043f\u0440\u0435\u043a\u044a\u0441\u043d\u0430\u0442\u043e \u0443\u0441\u0438\u043b\u0438\u0435. \u0420\u0435\u0434\u043e\u0432\u043d\u043e \u043f\u0440\u0435\u0433\u043b\u0435\u0436\u0434\u0430\u043c\u0435 \u043d\u0430\u0448\u0438\u044f \u0443\u0435\u0431\u0441\u0430\u0439\u0442 \u0438 \u043e\u0446\u0435\u043d\u044f\u0432\u0430\u043c\u0435 \u0432\u044a\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u0438 \u0437\u0430 \u043f\u043e\u0434\u043e\u0431\u0440\u044f\u0432\u0430\u043d\u0435 \u043d\u0430 \u0434\u043e\u0441\u0442\u044a\u043f\u043d\u043e\u0441\u0442\u0442\u0430 \u0438 \u0438\u0437\u043f\u043e\u043b\u0437\u0432\u0430\u0435\u043c\u043e\u0441\u0442\u0442\u0430.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003E\u041f\u043e\u0441\u043b\u0435\u0434\u043d\u0430 \u0430\u043a\u0442\u0443\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"\u043d\u0430\u043f\u044a\u043b\u043d\u043e \u0441\u044a\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0430","partially-conformant":"\u0447\u0430\u0441\u0442\u0438\u0447\u043d\u043e \u0441\u044a\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0430","non-conformant":"\u043d\u0435 \u0441\u044a\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0430","not-assessed":"\u043d\u044f\u043c\u0430 \u0434\u043e\u0441\u0442\u044a\u043f"}},"ca":{"template":"\u003Ch2\u003EComprom\u00eds amb l'accessibilitat\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E es compromet a millorar l'accessibilitat i la usabilitat de \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E per a tots els usuaris, incloses les persones amb discapacitat. Aspirem a oferir una experi\u00e8ncia digital inclusiva i treballem cont\u00ednuament per millorar l'accessibilitat del nostre lloc web.\u003C/p\u003E\n\u003Ch2\u003EEst\u00e0ndard d'accessibilitat objectiu\u003C/h2\u003E\n\u003Cp\u003EPretenem alinear el nostre lloc web amb l'est\u00e0ndard d'accessibilitat \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EAquest est\u00e0ndard de refer\u00e8ncia orienta els nostres esfor\u00e7os i les millores cont\u00ednues en mat\u00e8ria d'accessibilitat.\u003C/p\u003E\n\u003Ch2\u003EEstat actual de conformitat\u003C/h2\u003E\n\u003Cp\u003ESegons la nostra revisi\u00f3 interna, aquest lloc web \u00e9s \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E respecte de \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EAquest estat reflecteix la nostra avaluaci\u00f3 en el moment de la publicaci\u00f3 i es basa en la revisi\u00f3 interna i la informaci\u00f3 disponible. L'accessibilitat \u00e9s un proc\u00e9s continu; els nivells de conformitat poden evolucionar a mesura que s'implementen actualitzacions.\u003C/p\u003E\n\u003Ch2\u003EFuncionalitats d'accessibilitat\u003C/h2\u003E\n\u003Cp\u003EPer donar suport a l'accessibilitat, aquest lloc inclou la interf\u00edcie d'accessibilitat AccessYes. Aquesta interf\u00edcie permet ajustar determinats par\u00e0metres visuals i d'usabilitat segons les necessitats individuals, com ara:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003EAjustos de la mida i l'espaiat del text\u003C/li\u003E\n\u003Cli\u003EPar\u00e0metres de contrast i color\u003C/li\u003E\n\u003Cli\u003EEines de ressaltat\u003C/li\u003E\n\u003Cli\u003EAltres opcions de visualitzaci\u00f3 assistida\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003EAquestes eines tenen com a finalitat millorar l'experi\u00e8ncia d'usuari, per\u00f2 no substitueixen la necessitat de contingut accessible i d'una estructura t\u00e8cnica adequada del lloc.\u003C/p\u003E\n\u003Ch2\u003ELimitacions i consideracions t\u00e8cniques\u003C/h2\u003E\n\u003Cp\u003ETingueu en compte el seg\u00fcent:\u003C/p\u003E\n\u003Cp\u003ELa disponibilitat i l'efectivitat de les funcionalitats d'accessibilitat depenen de la configuraci\u00f3 del lloc web i del manteniment continu.\u003C/p\u003E\n\u003Cp\u003ETot i que ens esforcem per garantir l'accessibilitat a \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, \u00e9s possible que alguns continguts o funcionalitats encara no compleixin plenament els est\u00e0ndards d'accessibilitat seleccionats. Alguns continguts poden ser proporcionats per tercers o estar afectats per limitacions t\u00e8cniques fora del nostre control immediat.\u003C/p\u003E\n\u003Cp\u003EA m\u00e9s, pot haver-hi contingut o integracions heretades que encara no s'ajustin completament a l'est\u00e0ndard d'accessibilitat seleccionat. Treballem activament per identificar i abordar les barreres d'accessibilitat que estan sota el nostre control.\u003C/p\u003E\n\u003Ch2\u003EComentaris i contacte\u003C/h2\u003E\n\u003Cp\u003ESi experimenteu cap dificultat per accedir al contingut d'aquest lloc o voleu informar d'un problema d'accessibilitat, contacteu amb nosaltres:\u003C/p\u003E\n\u003Cp\u003ECorreu electr\u00f2nic: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003EEn contactar, incloeu l'URL espec\u00edfic de la p\u00e0gina i una descripci\u00f3 del problema perqu\u00e8 puguem investigar-lo i respondre adequadament.\u003C/p\u003E\n\u003Ch2\u003EMillora cont\u00ednua\u003C/h2\u003E\n\u003Cp\u003EL'accessibilitat \u00e9s un esfor\u00e7 continu. Revisem regularment el nostre lloc i avaluem oportunitats per millorar l'accessibilitat i la usabilitat.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003EDarrera actualitzaci\u00f3: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"totalment conforme","partially-conformant":"parcialment conforme","non-conformant":"no conforme","not-assessed":"no s'hi ha accedit"}},"cs":{"template":"\u003Ch2\u003EZ\u00e1vazek k p\u0159\u00edstupnosti\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E se zavazuje zlep\u0161ovat p\u0159\u00edstupnost a pou\u017eitelnost webu \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E pro v\u0161echny u\u017eivatele, v\u010detn\u011b osob se zdravotn\u00edm posti\u017een\u00edm. Na\u0161\u00edm c\u00edlem je inkluzivn\u00ed digit\u00e1ln\u00ed prost\u0159ed\u00ed a pr\u016fb\u011b\u017en\u011b pracujeme na zvy\u0161ov\u00e1n\u00ed p\u0159\u00edstupnosti na na\u0161em webu.\u003C/p\u003E\n\u003Ch2\u003EC\u00edlov\u00fd standard p\u0159\u00edstupnosti\u003C/h2\u003E\n\u003Cp\u003EUsilujeme o slad\u011bn\u00ed na\u0161eho webu se standardem p\u0159\u00edstupnosti \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003ETento c\u00edlov\u00fd standard \u0159\u00edd\u00ed na\u0161e \u00fasil\u00ed v oblasti p\u0159\u00edstupnosti i pr\u016fb\u011b\u017en\u00e1 zlep\u0161en\u00ed.\u003C/p\u003E\n\u003Ch2\u003EAktu\u00e1ln\u00ed stav shody\u003C/h2\u003E\n\u003Cp\u003ENa z\u00e1klad\u011b na\u0161\u00ed intern\u00ed kontroly je tento web \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E v\u016f\u010di \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003ETento stav odr\u00e1\u017e\u00ed na\u0161e hodnocen\u00ed v dob\u011b zve\u0159ejn\u011bn\u00ed a vych\u00e1z\u00ed z intern\u00ed revize a dostupn\u00fdch informac\u00ed. P\u0159\u00edstupnost je trval\u00fd proces a \u00farovn\u011b shody se mohou vyv\u00edjet s pr\u016fb\u011b\u017en\u00fdmi aktualizacemi.\u003C/p\u003E\n\u003Ch2\u003EFunkce p\u0159\u00edstupnosti\u003C/h2\u003E\n\u003Cp\u003EZa \u00fa\u010delem podpory p\u0159\u00edstupnosti tento web zahrnuje rozhran\u00ed p\u0159\u00edstupnosti AccessYes. Toto rozhran\u00ed umo\u017e\u0148uje u\u017eivatel\u016fm upravit n\u011bkter\u00e1 vizu\u00e1ln\u00ed a u\u017eivatelsk\u00e1 nastaven\u00ed dle individu\u00e1ln\u00edch pot\u0159eb, nap\u0159\u00edklad:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003E\u00dapravy velikosti textu a mezer\u003C/li\u003E\n\u003Cli\u003ENastaven\u00ed kontrastu a barev\u003C/li\u003E\n\u003Cli\u003EN\u00e1stroje pro zv\u00fdraz\u0148ov\u00e1n\u00ed\u003C/li\u003E\n\u003Cli\u003EDal\u0161\u00ed mo\u017enosti asistovan\u00e9ho zobrazen\u00ed\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003ETyto n\u00e1stroje maj\u00ed za c\u00edl zlep\u0161it u\u017eivatelskou zku\u0161enost, nenahrazuj\u00ed v\u0161ak pot\u0159ebu p\u0159\u00edstupn\u00e9ho obsahu a odpov\u00eddaj\u00edc\u00ed technick\u00e9 struktury webu.\u003C/p\u003E\n\u003Ch2\u003EOmezen\u00ed a technick\u00e1 hlediska\u003C/h2\u003E\n\u003Cp\u003EVezm\u011bte pros\u00edm na v\u011bdom\u00ed n\u00e1sleduj\u00edc\u00ed:\u003C/p\u003E\n\u003Cp\u003EDostupnost a \u00fa\u010dinnost funkc\u00ed p\u0159\u00edstupnosti z\u00e1vis\u00ed na konfiguraci webu a pr\u016fb\u011b\u017en\u00e9 \u00fadr\u017eb\u011b.\u003C/p\u003E\n\u003Cp\u003EA\u010dkoli usilujeme o zaji\u0161t\u011bn\u00ed p\u0159\u00edstupnosti nap\u0159\u00ed\u010d \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, n\u011bkter\u00fd obsah \u010di funkce zat\u00edm nemus\u00ed pln\u011b spl\u0148ovat vybran\u00e9 standardy p\u0159\u00edstupnosti. \u010c\u00e1st obsahu m\u016f\u017ee poch\u00e1zet od t\u0159et\u00edch stran nebo b\u00fdt ovlivn\u011bna technick\u00fdmi omezen\u00edmi mimo na\u0161i bezprost\u0159edn\u00ed kontrolu.\u003C/p\u003E\n\u003Cp\u003ED\u00e1le se m\u016f\u017ee vyskytovat star\u0161\u00ed obsah \u010di integrace, kter\u00e9 zat\u00edm nejsou pln\u011b slad\u011bny s vybran\u00fdm standardem p\u0159\u00edstupnosti. Aktivn\u011b pracujeme na identifikaci a odstra\u0148ov\u00e1n\u00ed bari\u00e9r v p\u0159\u00edstupnosti, je\u017e jsou v na\u0161em dosahu.\u003C/p\u003E\n\u003Ch2\u003EZp\u011btn\u00e1 vazba a kontakt\u003C/h2\u003E\n\u003Cp\u003EPokud se setk\u00e1te s obt\u00ed\u017eemi p\u0159i p\u0159\u00edstupu k obsahu tohoto webu nebo chcete nahl\u00e1sit probl\u00e9m s p\u0159\u00edstupnost\u00ed, kontaktujte n\u00e1s:\u003C/p\u003E\n\u003Cp\u003EE&#8209;mail: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003EUve\u010fte pros\u00edm konkr\u00e9tn\u00ed URL str\u00e1nky a popis probl\u00e9mu, abychom mohli z\u00e1le\u017eitost prov\u011b\u0159it a adekv\u00e1tn\u011b reagovat.\u003C/p\u003E\n\u003Ch2\u003EPr\u016fb\u011b\u017en\u00e9 zlep\u0161ov\u00e1n\u00ed\u003C/h2\u003E\n\u003Cp\u003EP\u0159\u00edstupnost je kontinu\u00e1ln\u00ed \u00fasil\u00ed. Pravideln\u011b p\u0159ezkoum\u00e1v\u00e1me n\u00e1\u0161 web a vyhodnocujeme p\u0159\u00edle\u017eitosti ke zlep\u0161en\u00ed p\u0159\u00edstupnosti a pou\u017eitelnosti.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003EPosledn\u00ed aktualizace: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"pln\u011b vyhovuj\u00edc\u00ed","partially-conformant":"\u010d\u00e1ste\u010dn\u011b vyhovuj\u00edc\u00ed","non-conformant":"nevyhovuj\u00edc\u00ed","not-assessed":"nep\u0159istoupeno"}},"de":{"template":"\u003Ch2\u003EEngagement f\u00fcr Barrierefreiheit\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E verpflichtet sich, die Barrierefreiheit und Nutzbarkeit von \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E f\u00fcr alle Nutzerinnen und Nutzer \u2014 einschlie\u00dflich Menschen mit Behinderungen \u2014 zu verbessern. Wir streben eine inklusive digitale Erfahrung an und arbeiten fortlaufend daran, die Barrierefreiheit auf unserer Website zu verbessern.\u003C/p\u003E\n\u003Ch2\u003EZiel-Standard f\u00fcr Barrierefreiheit\u003C/h2\u003E\n\u003Cp\u003EWir beabsichtigen, unsere Website an den Barrierefreiheitsstandard \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E anzugleichen.\u003C/p\u003E\n\u003Cp\u003EDieser Ziel-Standard leitet unsere Bem\u00fchungen und fortlaufenden Verbesserungen im Bereich Barrierefreiheit.\u003C/p\u003E\n\u003Ch2\u003EAktueller Konformit\u00e4tsstatus\u003C/h2\u003E\n\u003Cp\u003EAuf Grundlage unserer internen \u00dcberpr\u00fcfung ist diese Website \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E in Bezug auf \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EDieser Status spiegelt unsere Bewertung zum Zeitpunkt der Ver\u00f6ffentlichung wider und basiert auf unserer internen Pr\u00fcfung sowie den verf\u00fcgbaren Informationen. Barrierefreiheit ist ein fortlaufender Prozess; Konformit\u00e4tsgrade k\u00f6nnen sich mit weiteren Aktualisierungen \u00e4ndern.\u003C/p\u003E\n\u003Ch2\u003EBarrierefreiheitsfunktionen\u003C/h2\u003E\n\u003Cp\u003EZur Unterst\u00fctzung der Barrierefreiheit umfasst diese Website die Barrierefreiheits-Schnittstelle AccessYes. Diese Schnittstelle erm\u00f6glicht es Nutzenden, bestimmte visuelle und funktionale Einstellungen an individuelle Bed\u00fcrfnisse anzupassen, etwa:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003EAnpassungen von Schriftgr\u00f6\u00dfe und Abst\u00e4nden\u003C/li\u003E\n\u003Cli\u003EKontrast- und Farbeinstellungen\u003C/li\u003E\n\u003Cli\u003EHervorhebungs-Werkzeuge\u003C/li\u003E\n\u003Cli\u003EWeitere Optionen f\u00fcr unterst\u00fctzte Darstellung\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003EDiese Werkzeuge sollen die User Experience verbessern, ersetzen jedoch nicht die Notwendigkeit barrierefreier Inhalte und einer sachgerechten technischen Struktur der Website.\u003C/p\u003E\n\u003Ch2\u003EEinschr\u00e4nkungen und technische Aspekte\u003C/h2\u003E\n\u003Cp\u003EBitte beachten Sie Folgendes:\u003C/p\u003E\n\u003Cp\u003EVerf\u00fcgbarkeit und Wirksamkeit der Barrierefreiheitsfunktionen h\u00e4ngen von der Konfiguration der Website und der laufenden Wartung ab.\u003C/p\u003E\n\u003Cp\u003EObwohl wir uns bem\u00fchen, die Barrierefreiheit auf \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E sicherzustellen, erf\u00fcllen manche Inhalte oder Funktionen die ausgew\u00e4hlten Standards unter Umst\u00e4nden noch nicht vollst\u00e4ndig. Einige Inhalte k\u00f6nnen von Dritten bereitgestellt sein oder durch technische Rahmenbedingungen au\u00dferhalb unseres unmittelbaren Einflusses beeintr\u00e4chtigt werden.\u003C/p\u003E\n\u003Cp\u003EDar\u00fcber hinaus kann es Altinhalte oder Integrationen geben, die noch nicht vollst\u00e4ndig mit dem ausgew\u00e4hlten Standard im Einklang stehen. Wir arbeiten aktiv daran, Barrieren innerhalb unseres Einflussbereichs zu identifizieren und zu beseitigen.\u003C/p\u003E\n\u003Ch2\u003ER\u00fcckmeldungen und Kontakt\u003C/h2\u003E\n\u003Cp\u003ESollten Sie Schwierigkeiten beim Zugriff auf Inhalte dieser Website haben oder ein Barrierefreiheitsproblem melden wollen, kontaktieren Sie uns bitte:\u003C/p\u003E\n\u003Cp\u003EE&#8209;Mail: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003EBitte f\u00fcgen Sie in Ihrer Nachricht die URL der betreffenden Seite und eine Problembeschreibung bei, damit wir den Sachverhalt pr\u00fcfen und angemessen reagieren k\u00f6nnen.\u003C/p\u003E\n\u003Ch2\u003EKontinuierliche Verbesserung\u003C/h2\u003E\n\u003Cp\u003EBarrierefreiheit ist eine kontinuierliche Aufgabe. Wir \u00fcberpr\u00fcfen unsere Website regelm\u00e4\u00dfig und evaluieren M\u00f6glichkeiten zur Verbesserung von Barrierefreiheit und Nutzbarkeit.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003EZuletzt aktualisiert: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"vollst\u00e4ndig konform","partially-conformant":"teilweise konform","non-conformant":"nicht konform","not-assessed":"nicht aufgerufen"}},"el":{"template":"\u003Ch2\u003E\u0394\u03ad\u03c3\u03bc\u03b5\u03c5\u03c3\u03b7 \u03b3\u03b9\u03b1 \u03c4\u03b7\u03bd \u03a0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E \u03b4\u03b5\u03c3\u03bc\u03b5\u03cd\u03b5\u03c4\u03b1\u03b9 \u03bd\u03b1 \u03b2\u03b5\u03bb\u03c4\u03b9\u03ce\u03bd\u03b5\u03b9 \u03c4\u03b7\u03bd \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1 \u03ba\u03b1\u03b9 \u03c4\u03b7 \u03c7\u03c1\u03b7\u03c3\u03c4\u03b9\u03ba\u03cc\u03c4\u03b7\u03c4\u03b1 \u03c4\u03bf\u03c5 \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E \u03b3\u03b9\u03b1 \u03cc\u03bb\u03bf\u03c5\u03c2 \u03c4\u03bf\u03c5\u03c2 \u03c7\u03c1\u03ae\u03c3\u03c4\u03b5\u03c2, \u03c3\u03c5\u03bc\u03c0\u03b5\u03c1\u03b9\u03bb\u03b1\u03bc\u03b2\u03b1\u03bd\u03bf\u03bc\u03ad\u03bd\u03c9\u03bd \u03c4\u03c9\u03bd \u03b1\u03c4\u03cc\u03bc\u03c9\u03bd \u03bc\u03b5 \u03b1\u03bd\u03b1\u03c0\u03b7\u03c1\u03af\u03b1. \u03a3\u03c4\u03cc\u03c7\u03bf\u03c2 \u03bc\u03b1\u03c2 \u03b5\u03af\u03bd\u03b1\u03b9 \u03bc\u03b9\u03b1 \u03c7\u03c9\u03c1\u03af\u03c2 \u03b1\u03c0\u03bf\u03ba\u03bb\u03b5\u03b9\u03c3\u03bc\u03bf\u03cd\u03c2 \u03c8\u03b7\u03c6\u03b9\u03b1\u03ba\u03ae \u03b5\u03bc\u03c0\u03b5\u03b9\u03c1\u03af\u03b1 \u03ba\u03b1\u03b9 \u03b5\u03c1\u03b3\u03b1\u03b6\u03cc\u03bc\u03b1\u03c3\u03c4\u03b5 \u03b4\u03b9\u03b1\u03c1\u03ba\u03ce\u03c2 \u03b3\u03b9\u03b1 \u03c4\u03b7 \u03b2\u03b5\u03bb\u03c4\u03af\u03c9\u03c3\u03b7 \u03c4\u03b7\u03c2 \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2 \u03c3\u03c4\u03bf\u03bd \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03cc \u03bc\u03b1\u03c2.\u003C/p\u003E\n\u003Ch2\u003E\u03a3\u03c4\u03cc\u03c7\u03bf\u03c2 \u03a0\u03c1\u03bf\u03c4\u03cd\u03c0\u03bf\u03c5 \u03a0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2\u003C/h2\u003E\n\u003Cp\u003E\u03a3\u03c4\u03bf\u03c7\u03b5\u03cd\u03bf\u03c5\u03bc\u03b5 \u03c3\u03c4\u03b7\u03bd \u03b5\u03c5\u03b8\u03c5\u03b3\u03c1\u03ac\u03bc\u03bc\u03b9\u03c3\u03b7 \u03c4\u03bf\u03c5 \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03bf\u03cd \u03bc\u03b1\u03c2 \u03bc\u03b5 \u03c4\u03bf \u03c0\u03c1\u03cc\u03c4\u03c5\u03c0\u03bf \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2 \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003E\u03a4\u03bf \u03c3\u03c5\u03b3\u03ba\u03b5\u03ba\u03c1\u03b9\u03bc\u03ad\u03bd\u03bf \u03c0\u03c1\u03cc\u03c4\u03c5\u03c0\u03bf \u03ba\u03b1\u03c4\u03b5\u03c5\u03b8\u03cd\u03bd\u03b5\u03b9 \u03c4\u03b9\u03c2 \u03c0\u03c1\u03bf\u03c3\u03c0\u03ac\u03b8\u03b5\u03b9\u03ad\u03c2 \u03bc\u03b1\u03c2 \u03ba\u03b1\u03b9 \u03c4\u03b9\u03c2 \u03c3\u03c5\u03bd\u03b5\u03c7\u03b9\u03b6\u03cc\u03bc\u03b5\u03bd\u03b5\u03c2 \u03b2\u03b5\u03bb\u03c4\u03b9\u03ce\u03c3\u03b5\u03b9\u03c2 \u03c3\u03c4\u03b7\u03bd \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1.\u003C/p\u003E\n\u003Ch2\u003E\u03a4\u03c1\u03ad\u03c7\u03bf\u03c5\u03c3\u03b1 \u039a\u03b1\u03c4\u03ac\u03c3\u03c4\u03b1\u03c3\u03b7 \u03a3\u03c5\u03bc\u03bc\u03cc\u03c1\u03c6\u03c9\u03c3\u03b7\u03c2\u003C/h2\u003E\n\u003Cp\u003E\u0392\u03ac\u03c3\u03b5\u03b9 \u03c4\u03b7\u03c2 \u03b5\u03c3\u03c9\u03c4\u03b5\u03c1\u03b9\u03ba\u03ae\u03c2 \u03bc\u03b1\u03c2 \u03b1\u03be\u03b9\u03bf\u03bb\u03cc\u03b3\u03b7\u03c3\u03b7\u03c2, \u03bf \u03c0\u03b1\u03c1\u03ce\u03bd \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03bf\u03c2 \u03b5\u03af\u03bd\u03b1\u03b9 \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E \u03c3\u03b5 \u03c3\u03c7\u03ad\u03c3\u03b7 \u03bc\u03b5 \u03c4\u03bf \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003E\u0397 \u03ba\u03b1\u03c4\u03ac\u03c3\u03c4\u03b1\u03c3\u03b7 \u03b1\u03c5\u03c4\u03ae \u03b1\u03bd\u03c4\u03b9\u03ba\u03b1\u03c4\u03bf\u03c0\u03c4\u03c1\u03af\u03b6\u03b5\u03b9 \u03c4\u03b7\u03bd \u03b1\u03be\u03b9\u03bf\u03bb\u03cc\u03b3\u03b7\u03c3\u03ae \u03bc\u03b1\u03c2 \u03ba\u03b1\u03c4\u03ac \u03c4\u03bf\u03bd \u03c7\u03c1\u03cc\u03bd\u03bf \u03b4\u03b7\u03bc\u03bf\u03c3\u03af\u03b5\u03c5\u03c3\u03b7\u03c2 \u03ba\u03b1\u03b9 \u03b2\u03b1\u03c3\u03af\u03b6\u03b5\u03c4\u03b1\u03b9 \u03c3\u03c4\u03b7\u03bd \u03b5\u03c3\u03c9\u03c4\u03b5\u03c1\u03b9\u03ba\u03ae \u03bc\u03b1\u03c2 \u03b1\u03bd\u03b1\u03c3\u03ba\u03cc\u03c0\u03b7\u03c3\u03b7 \u03ba\u03b1\u03b9 \u03c3\u03c4\u03b9\u03c2 \u03b4\u03b9\u03b1\u03b8\u03ad\u03c3\u03b9\u03bc\u03b5\u03c2 \u03c0\u03bb\u03b7\u03c1\u03bf\u03c6\u03bf\u03c1\u03af\u03b5\u03c2. \u0397 \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1 \u03b1\u03c0\u03bf\u03c4\u03b5\u03bb\u03b5\u03af \u03bc\u03b9\u03b1 \u03b4\u03b9\u03b1\u03c1\u03ba\u03ae \u03b4\u03b9\u03b1\u03b4\u03b9\u03ba\u03b1\u03c3\u03af\u03b1 \u03ba\u03b1\u03b9 \u03c4\u03b1 \u03b5\u03c0\u03af\u03c0\u03b5\u03b4\u03b1 \u03c3\u03c5\u03bc\u03bc\u03cc\u03c1\u03c6\u03c9\u03c3\u03b7\u03c2 \u03b5\u03bd\u03b4\u03ad\u03c7\u03b5\u03c4\u03b1\u03b9 \u03bd\u03b1 \u03b5\u03be\u03b5\u03bb\u03af\u03c3\u03c3\u03bf\u03bd\u03c4\u03b1\u03b9 \u03ba\u03b1\u03b8\u03ce\u03c2 \u03c5\u03bb\u03bf\u03c0\u03bf\u03b9\u03bf\u03cd\u03bd\u03c4\u03b1\u03b9 \u03b5\u03bd\u03b7\u03bc\u03b5\u03c1\u03ce\u03c3\u03b5\u03b9\u03c2.\u003C/p\u003E\n\u003Ch2\u003E\u039b\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03af\u03b5\u03c2 \u03a0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2\u003C/h2\u003E\n\u003Cp\u003E\u0393\u03b9\u03b1 \u03c4\u03b7\u03bd \u03c5\u03c0\u03bf\u03c3\u03c4\u03ae\u03c1\u03b9\u03be\u03b7 \u03c4\u03b7\u03c2 \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2, \u03bf \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03bf\u03c2 \u03b1\u03c5\u03c4\u03cc\u03c2 \u03c0\u03b5\u03c1\u03b9\u03bb\u03b1\u03bc\u03b2\u03ac\u03bd\u03b5\u03b9 \u03c4\u03b7 \u03b4\u03b9\u03b5\u03c0\u03b1\u03c6\u03ae \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2 AccessYes. \u0397 \u03b4\u03b9\u03b5\u03c0\u03b1\u03c6\u03ae \u03b1\u03c5\u03c4\u03ae \u03b5\u03c0\u03b9\u03c4\u03c1\u03ad\u03c0\u03b5\u03b9 \u03c3\u03c4\u03bf\u03c5\u03c2 \u03c7\u03c1\u03ae\u03c3\u03c4\u03b5\u03c2 \u03bd\u03b1 \u03c0\u03c1\u03bf\u03c3\u03b1\u03c1\u03bc\u03cc\u03b6\u03bf\u03c5\u03bd \u03bf\u03c1\u03b9\u03c3\u03bc\u03ad\u03bd\u03b5\u03c2 \u03bf\u03c0\u03c4\u03b9\u03ba\u03ad\u03c2 \u03ba\u03b1\u03b9 \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03b9\u03ba\u03ad\u03c2 \u03c1\u03c5\u03b8\u03bc\u03af\u03c3\u03b5\u03b9\u03c2 \u03b1\u03bd\u03ac\u03bb\u03bf\u03b3\u03b1 \u03bc\u03b5 \u03c4\u03b9\u03c2 \u03b1\u03bd\u03ac\u03b3\u03ba\u03b5\u03c2 \u03c4\u03bf\u03c5\u03c2, \u03cc\u03c0\u03c9\u03c2:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003E\u03a0\u03c1\u03bf\u03c3\u03b1\u03c1\u03bc\u03bf\u03b3\u03ad\u03c2 \u03bc\u03b5\u03b3\u03ad\u03b8\u03bf\u03c5\u03c2 \u03ba\u03b1\u03b9 \u03b1\u03c0\u03bf\u03c3\u03c4\u03ac\u03c3\u03b5\u03c9\u03bd \u03ba\u03b5\u03b9\u03bc\u03ad\u03bd\u03bf\u03c5\u003C/li\u003E\n\u003Cli\u003E\u03a1\u03c5\u03b8\u03bc\u03af\u03c3\u03b5\u03b9\u03c2 \u03b1\u03bd\u03c4\u03af\u03b8\u03b5\u03c3\u03b7\u03c2 \u03ba\u03b1\u03b9 \u03c7\u03c1\u03c9\u03bc\u03ac\u03c4\u03c9\u03bd\u003C/li\u003E\n\u003Cli\u003E\u0395\u03c1\u03b3\u03b1\u03bb\u03b5\u03af\u03b1 \u03b5\u03c0\u03b9\u03c3\u03ae\u03bc\u03b1\u03bd\u03c3\u03b7\u03c2\u003C/li\u003E\n\u003Cli\u003E\u0386\u03bb\u03bb\u03b5\u03c2 \u03b5\u03c0\u03b9\u03bb\u03bf\u03b3\u03ad\u03c2 \u03c5\u03c0\u03bf\u03b2\u03bf\u03b7\u03b8\u03bf\u03cd\u03bc\u03b5\u03bd\u03b7\u03c2 \u03c0\u03c1\u03bf\u03b2\u03bf\u03bb\u03ae\u03c2\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003E\u03a4\u03b1 \u03b5\u03c1\u03b3\u03b1\u03bb\u03b5\u03af\u03b1 \u03b1\u03c5\u03c4\u03ac \u03b1\u03c0\u03bf\u03c3\u03ba\u03bf\u03c0\u03bf\u03cd\u03bd \u03c3\u03c4\u03b7 \u03b2\u03b5\u03bb\u03c4\u03af\u03c9\u03c3\u03b7 \u03c4\u03b7\u03c2 \u03b5\u03bc\u03c0\u03b5\u03b9\u03c1\u03af\u03b1\u03c2 \u03c7\u03c1\u03ae\u03c3\u03b7\u03c2, \u03b1\u03bb\u03bb\u03ac \u03b4\u03b5\u03bd \u03c5\u03c0\u03bf\u03ba\u03b1\u03b8\u03b9\u03c3\u03c4\u03bf\u03cd\u03bd \u03c4\u03b7\u03bd \u03b1\u03bd\u03ac\u03b3\u03ba\u03b7 \u03b3\u03b9\u03b1 \u03c0\u03c1\u03bf\u03c3\u03b2\u03ac\u03c3\u03b9\u03bc\u03bf \u03c0\u03b5\u03c1\u03b9\u03b5\u03c7\u03cc\u03bc\u03b5\u03bd\u03bf \u03ba\u03b1\u03b9 \u03bf\u03c1\u03b8\u03ae \u03c5\u03c0\u03bf\u03ba\u03b5\u03af\u03bc\u03b5\u03bd\u03b7 \u03b4\u03bf\u03bc\u03ae \u03c4\u03bf\u03c5 \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03bf\u03c5.\u003C/p\u003E\n\u003Ch2\u003E\u03a0\u03b5\u03c1\u03b9\u03bf\u03c1\u03b9\u03c3\u03bc\u03bf\u03af \u03ba\u03b1\u03b9 \u03a4\u03b5\u03c7\u03bd\u03b9\u03ba\u03ad\u03c2 \u03a0\u03b1\u03c1\u03ac\u03bc\u03b5\u03c4\u03c1\u03bf\u03b9\u003C/h2\u003E\n\u003Cp\u003E\u039b\u03ac\u03b2\u03b5\u03c4\u03b5 \u03c5\u03c0\u03cc\u03c8\u03b7 \u03c4\u03b1 \u03b5\u03be\u03ae\u03c2:\u003C/p\u003E\n\u003Cp\u003E\u0397 \u03b4\u03b9\u03b1\u03b8\u03b5\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1 \u03ba\u03b1\u03b9 \u03b7 \u03b1\u03c0\u03bf\u03c4\u03b5\u03bb\u03b5\u03c3\u03bc\u03b1\u03c4\u03b9\u03ba\u03cc\u03c4\u03b7\u03c4\u03b1 \u03c4\u03c9\u03bd \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03b9\u03ce\u03bd \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2 \u03b5\u03be\u03b1\u03c1\u03c4\u03ce\u03bd\u03c4\u03b1\u03b9 \u03b1\u03c0\u03cc \u03c4\u03b7 \u03c1\u03cd\u03b8\u03bc\u03b9\u03c3\u03b7 \u03c4\u03bf\u03c5 \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03bf\u03c5 \u03ba\u03b1\u03b9 \u03c4\u03b7 \u03c3\u03c5\u03bd\u03b5\u03c7\u03ae \u03c3\u03c5\u03bd\u03c4\u03ae\u03c1\u03b7\u03c3\u03b7.\u003C/p\u003E\n\u003Cp\u003E\u03a0\u03b1\u03c1\u03cc\u03c4\u03b9 \u03ba\u03b1\u03c4\u03b1\u03b2\u03ac\u03bb\u03bb\u03bf\u03c5\u03bc\u03b5 \u03c0\u03c1\u03bf\u03c3\u03c0\u03ac\u03b8\u03b5\u03b9\u03b5\u03c2 \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03b4\u03b9\u03b1\u03c3\u03c6\u03b1\u03bb\u03af\u03c3\u03bf\u03c5\u03bc\u03b5 \u03c4\u03b7\u03bd \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1 \u03c3\u03b5 \u03bf\u03bb\u03cc\u03ba\u03bb\u03b7\u03c1\u03bf \u03c4\u03bf \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, \u03b5\u03bd\u03b4\u03ad\u03c7\u03b5\u03c4\u03b1\u03b9 \u03bf\u03c1\u03b9\u03c3\u03bc\u03ad\u03bd\u03bf \u03c0\u03b5\u03c1\u03b9\u03b5\u03c7\u03cc\u03bc\u03b5\u03bd\u03bf \u03ae \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03af\u03b5\u03c2 \u03bd\u03b1 \u03bc\u03b7\u03bd \u03c0\u03bb\u03b7\u03c1\u03bf\u03cd\u03bd \u03b1\u03ba\u03cc\u03bc\u03b7 \u03c0\u03bb\u03ae\u03c1\u03c9\u03c2 \u03c4\u03b1 \u03b5\u03c0\u03b9\u03bb\u03b5\u03b3\u03bc\u03ad\u03bd\u03b1 \u03c0\u03c1\u03cc\u03c4\u03c5\u03c0\u03b1 \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2. \u039f\u03c1\u03b9\u03c3\u03bc\u03ad\u03bd\u03bf \u03c0\u03b5\u03c1\u03b9\u03b5\u03c7\u03cc\u03bc\u03b5\u03bd\u03bf \u03b5\u03bd\u03b4\u03ad\u03c7\u03b5\u03c4\u03b1\u03b9 \u03bd\u03b1 \u03c0\u03b1\u03c1\u03ad\u03c7\u03b5\u03c4\u03b1\u03b9 \u03b1\u03c0\u03cc \u03c4\u03c1\u03af\u03c4\u03bf\u03c5\u03c2 \u03ae \u03bd\u03b1 \u03b5\u03c0\u03b7\u03c1\u03b5\u03ac\u03b6\u03b5\u03c4\u03b1\u03b9 \u03b1\u03c0\u03cc \u03c4\u03b5\u03c7\u03bd\u03b9\u03ba\u03bf\u03cd\u03c2 \u03c0\u03b5\u03c1\u03b9\u03bf\u03c1\u03b9\u03c3\u03bc\u03bf\u03cd\u03c2 \u03c0\u03ad\u03c1\u03b1 \u03b1\u03c0\u03cc \u03c4\u03bf\u03bd \u03ac\u03bc\u03b5\u03c3\u03bf \u03ad\u03bb\u03b5\u03b3\u03c7\u03cc \u03bc\u03b1\u03c2.\u003C/p\u003E\n\u003Cp\u003E\u0395\u03c0\u03b9\u03c0\u03bb\u03ad\u03bf\u03bd, \u03bc\u03c0\u03bf\u03c1\u03b5\u03af \u03bd\u03b1 \u03c5\u03c0\u03ac\u03c1\u03c7\u03bf\u03c5\u03bd \u03bf\u03c1\u03b9\u03c3\u03bc\u03ad\u03bd\u03b1 \u03c0\u03b1\u03bb\u03b1\u03b9\u03cc\u03c4\u03b5\u03c1\u03b1 \u03c0\u03b5\u03c1\u03b9\u03b5\u03c7\u03cc\u03bc\u03b5\u03bd\u03b1 \u03ae \u03b5\u03bd\u03c3\u03c9\u03bc\u03b1\u03c4\u03ce\u03c3\u03b5\u03b9\u03c2 \u03c0\u03bf\u03c5 \u03b4\u03b5\u03bd \u03b5\u03c5\u03b8\u03c5\u03b3\u03c1\u03b1\u03bc\u03bc\u03af\u03b6\u03bf\u03bd\u03c4\u03b1\u03b9 \u03b1\u03ba\u03cc\u03bc\u03b7 \u03c0\u03bb\u03ae\u03c1\u03c9\u03c2 \u03bc\u03b5 \u03c4\u03bf \u03b5\u03c0\u03b9\u03bb\u03b5\u03b3\u03bc\u03ad\u03bd\u03bf \u03c0\u03c1\u03cc\u03c4\u03c5\u03c0\u03bf \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2. \u0395\u03c1\u03b3\u03b1\u03b6\u03cc\u03bc\u03b1\u03c3\u03c4\u03b5 \u03b5\u03bd\u03b5\u03c1\u03b3\u03ac \u03b3\u03b9\u03b1 \u03c4\u03bf\u03bd \u03b5\u03bd\u03c4\u03bf\u03c0\u03b9\u03c3\u03bc\u03cc \u03ba\u03b1\u03b9 \u03c4\u03b7\u03bd \u03b1\u03bd\u03c4\u03b9\u03bc\u03b5\u03c4\u03ce\u03c0\u03b9\u03c3\u03b7 \u03b5\u03bc\u03c0\u03bf\u03b4\u03af\u03c9\u03bd \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2 \u03c0\u03bf\u03c5 \u03b2\u03c1\u03af\u03c3\u03ba\u03bf\u03bd\u03c4\u03b1\u03b9 \u03c5\u03c0\u03cc \u03c4\u03bf\u03bd \u03ad\u03bb\u03b5\u03b3\u03c7\u03cc \u03bc\u03b1\u03c2.\u003C/p\u003E\n\u003Ch2\u003E\u0391\u03bd\u03b1\u03c4\u03c1\u03bf\u03c6\u03bf\u03b4\u03cc\u03c4\u03b7\u03c3\u03b7 \u03ba\u03b1\u03b9 \u0395\u03c0\u03b9\u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03af\u03b1\u003C/h2\u003E\n\u003Cp\u003E\u0395\u03ac\u03bd \u03b1\u03bd\u03c4\u03b9\u03bc\u03b5\u03c4\u03c9\u03c0\u03af\u03b6\u03b5\u03c4\u03b5 \u03b4\u03c5\u03c3\u03ba\u03bf\u03bb\u03af\u03b1 \u03c0\u03c1\u03cc\u03c3\u03b2\u03b1\u03c3\u03b7\u03c2 \u03c3\u03b5 \u03c0\u03b5\u03c1\u03b9\u03b5\u03c7\u03cc\u03bc\u03b5\u03bd\u03bf \u03c4\u03bf\u03c5 \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03bf\u03c5 \u03ae \u03b8\u03ad\u03bb\u03b5\u03c4\u03b5 \u03bd\u03b1 \u03b1\u03bd\u03b1\u03c6\u03ad\u03c1\u03b5\u03c4\u03b5 \u03b6\u03ae\u03c4\u03b7\u03bc\u03b1 \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2, \u03b5\u03c0\u03b9\u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03ae\u03c3\u03c4\u03b5 \u03bc\u03b1\u03b6\u03af \u03bc\u03b1\u03c2:\u003C/p\u003E\n\u003Cp\u003E\u0397\u03bb\u03b5\u03ba\u03c4\u03c1\u03bf\u03bd\u03b9\u03ba\u03cc \u03c4\u03b1\u03c7\u03c5\u03b4\u03c1\u03bf\u03bc\u03b5\u03af\u03bf: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003E\u039a\u03b1\u03c4\u03ac \u03c4\u03b7\u03bd \u03b5\u03c0\u03b9\u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03af\u03b1, \u03c0\u03b1\u03c1\u03b1\u03ba\u03b1\u03bb\u03bf\u03cd\u03bc\u03b5 \u03bd\u03b1 \u03c3\u03c5\u03bc\u03c0\u03b5\u03c1\u03b9\u03bb\u03ac\u03b2\u03b5\u03c4\u03b5 \u03c4\u03bf \u03c3\u03c5\u03b3\u03ba\u03b5\u03ba\u03c1\u03b9\u03bc\u03ad\u03bd\u03bf URL \u03c4\u03b7\u03c2 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1\u03c2 \u03ba\u03b1\u03b9 \u03c0\u03b5\u03c1\u03b9\u03b3\u03c1\u03b1\u03c6\u03ae \u03c4\u03bf\u03c5 \u03b6\u03b7\u03c4\u03ae\u03bc\u03b1\u03c4\u03bf\u03c2, \u03ce\u03c3\u03c4\u03b5 \u03bd\u03b1 \u03bc\u03c0\u03bf\u03c1\u03ad\u03c3\u03bf\u03c5\u03bc\u03b5 \u03bd\u03b1 \u03b4\u03b9\u03b5\u03c1\u03b5\u03c5\u03bd\u03ae\u03c3\u03bf\u03c5\u03bc\u03b5 \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03b1\u03bd\u03c4\u03b1\u03c0\u03bf\u03ba\u03c1\u03b9\u03b8\u03bf\u03cd\u03bc\u03b5 \u03ba\u03b1\u03c4\u03b1\u03bb\u03bb\u03ae\u03bb\u03c9\u03c2.\u003C/p\u003E\n\u003Ch2\u003E\u0394\u03b9\u03b1\u03c1\u03ba\u03ae\u03c2 \u0392\u03b5\u03bb\u03c4\u03af\u03c9\u03c3\u03b7\u003C/h2\u003E\n\u003Cp\u003E\u0397 \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1 \u03b1\u03c0\u03bf\u03c4\u03b5\u03bb\u03b5\u03af \u03b4\u03b9\u03b1\u03c1\u03ba\u03ae \u03c0\u03c1\u03bf\u03c3\u03c0\u03ac\u03b8\u03b5\u03b9\u03b1. \u0395\u03be\u03b5\u03c4\u03ac\u03b6\u03bf\u03c5\u03bc\u03b5 \u03c4\u03b1\u03ba\u03c4\u03b9\u03ba\u03ac \u03c4\u03bf\u03bd \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03cc \u03bc\u03b1\u03c2 \u03ba\u03b1\u03b9 \u03b1\u03be\u03b9\u03bf\u03bb\u03bf\u03b3\u03bf\u03cd\u03bc\u03b5 \u03b5\u03c5\u03ba\u03b1\u03b9\u03c1\u03af\u03b5\u03c2 \u03b3\u03b9\u03b1 \u03b2\u03b5\u03bb\u03c4\u03af\u03c9\u03c3\u03b7 \u03c4\u03b7\u03c2 \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2 \u03ba\u03b1\u03b9 \u03c4\u03b7\u03c2 \u03c7\u03c1\u03b7\u03c3\u03c4\u03b9\u03ba\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003E\u03a4\u03b5\u03bb\u03b5\u03c5\u03c4\u03b1\u03af\u03b1 \u03b5\u03bd\u03b7\u03bc\u03ad\u03c1\u03c9\u03c3\u03b7: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"\u03c0\u03bb\u03ae\u03c1\u03c9\u03c2 \u03c3\u03cd\u03bc\u03c6\u03c9\u03bd\u03bf","partially-conformant":"\u03bc\u03b5\u03c1\u03b9\u03ba\u03ce\u03c2 \u03c3\u03cd\u03bc\u03c6\u03c9\u03bd\u03bf","non-conformant":"\u03bc\u03b7 \u03c3\u03cd\u03bc\u03c6\u03c9\u03bd\u03bf","not-assessed":"\u03bc\u03b7 \u03c0\u03c1\u03bf\u03c3\u03c0\u03b5\u03bb\u03ac\u03c3\u03c4\u03b7\u03ba\u03b5"}},"en":{"template":"\u003Ch2\u003EAccessibility Commitment\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E is committed to improving the accessibility and usability of \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E for all users, including people with disabilities. We aim to provide an inclusive digital experience and continuously work toward enhancing accessibility across our website.\u003C/p\u003E\n\u003Ch2\u003EAccessibility Target Standard\u003C/h2\u003E\n\u003Cp\u003EWe aim to align our website with \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E accessibility standards.\u003C/p\u003E\n\u003Cp\u003EThis target standard guides our accessibility efforts and ongoing improvements.\u003C/p\u003E\n\u003Ch2\u003ECurrent Conformance Status\u003C/h2\u003E\n\u003Cp\u003EBased on our internal review, this website is \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E with \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EThis status reflects our evaluation at the time of publication and is based on our internal review and available information. Accessibility is an ongoing process, and conformance levels may evolve as updates are implemented.\u003C/p\u003E\n\u003Ch2\u003EAccessibility Features\u003C/h2\u003E\n\u003Cp\u003ETo support accessibility, this website includes the AccessYes accessibility interface. This interface allows users to adjust certain visual and usability settings according to their individual needs, such as:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003EText size and spacing adjustments\u003C/li\u003E\n\u003Cli\u003EContrast and color settings\u003C/li\u003E\n\u003Cli\u003EHighlighting tools\u003C/li\u003E\n\u003Cli\u003EOther assistive viewing options\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003EThese tools are intended to improve user experience, but do not replace the need for accessible content and proper underlying website structure.\u003C/p\u003E\n\u003Ch2\u003ELimitations and Technical Considerations\u003C/h2\u003E\n\u003Cp\u003EPlease note the following:\u003C/p\u003E\n\u003Cp\u003EThe availability and effectiveness of accessibility features depend on the website's configuration and ongoing maintenance.\u003C/p\u003E\n\u003Cp\u003EWhile we strive to ensure accessibility across \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, some content or features may not yet fully meet the selected accessibility standards. Some content may be provided by third parties or affected by technical constraints beyond our immediate control.\u003C/p\u003E\n\u003Cp\u003EAdditionally, there may be certain legacy content or integrations that may not yet fully align with the selected accessibility standard. We are actively working to identify and address accessibility barriers within our control.\u003C/p\u003E\n\u003Ch2\u003EFeedback and Contact\u003C/h2\u003E\n\u003Cp\u003EIf you experience any difficulty accessing content on this website or would like to report an accessibility issue, please contact us:\u003C/p\u003E\n\u003Cp\u003EEmail: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003EWhen contacting us, please include the specific page URL and a description of the issue so we can investigate and respond appropriately.\u003C/p\u003E\n\u003Ch2\u003EContinuous Improvement\u003C/h2\u003E\n\u003Cp\u003EAccessibility is an ongoing effort. We regularly review our website and evaluate opportunities to improve accessibility and usability.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003ELast updated: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"Fully conformant","partially-conformant":"Partially conformant","non-conformant":"Non conformant","not-assessed":"Not assessed"}},"es":{"template":"\u003Ch2\u003ECompromiso con la accesibilidad\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E se compromete a mejorar la accesibilidad y la usabilidad de \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E para todos los usuarios, incluidas las personas con discapacidad. Nuestro objetivo es ofrecer una experiencia digital inclusiva y trabajamos de forma continua para mejorar la accesibilidad en todo nuestro sitio web.\u003C/p\u003E\n\u003Ch2\u003EEst\u00e1ndar de accesibilidad objetivo\u003C/h2\u003E\n\u003Cp\u003ENuestro objetivo es alinear nuestro sitio web con el est\u00e1ndar de accesibilidad \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EEste est\u00e1ndar de referencia gu\u00eda nuestros esfuerzos de accesibilidad y las mejoras continuas.\u003C/p\u003E\n\u003Ch2\u003EEstado actual de conformidad\u003C/h2\u003E\n\u003Cp\u003ESeg\u00fan nuestra revisi\u00f3n interna, este sitio web presenta un estado \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E con respecto a \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EEste estado refleja nuestra evaluaci\u00f3n en el momento de la publicaci\u00f3n y se basa en nuestra revisi\u00f3n interna y la informaci\u00f3n disponible. La accesibilidad es un proceso continuo, y los niveles de conformidad pueden evolucionar a medida que se implementan actualizaciones.\u003C/p\u003E\n\u003Ch2\u003EFunciones de accesibilidad\u003C/h2\u003E\n\u003Cp\u003EPara apoyar la accesibilidad, este sitio web incluye la interfaz de accesibilidad AccessYes. Esta interfaz permite a las personas usuarias ajustar determinados par\u00e1metros visuales y de usabilidad seg\u00fan sus necesidades, como:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003EAjustes de tama\u00f1o y espaciado del texto\u003C/li\u003E\n\u003Cli\u003EConfiguraci\u00f3n de contraste y color\u003C/li\u003E\n\u003Cli\u003EHerramientas de resaltado\u003C/li\u003E\n\u003Cli\u003EOtras opciones de visualizaci\u00f3n asistida\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003EEstas herramientas tienen como fin mejorar la experiencia de uso, pero no sustituyen la necesidad de contar con contenido accesible y con una estructura t\u00e9cnica adecuada del sitio web.\u003C/p\u003E\n\u003Ch2\u003ELimitaciones y consideraciones t\u00e9cnicas\u003C/h2\u003E\n\u003Cp\u003ETenga en cuenta lo siguiente:\u003C/p\u003E\n\u003Cp\u003ELa disponibilidad y eficacia de las funciones de accesibilidad dependen de la configuraci\u00f3n del sitio web y de su mantenimiento continuo.\u003C/p\u003E\n\u003Cp\u003ESi bien nos esforzamos por garantizar la accesibilidad en \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, es posible que algunos contenidos o funciones a\u00fan no cumplan plenamente con los est\u00e1ndares de accesibilidad seleccionados. Parte del contenido puede ser proporcionado por terceros o estar afectado por limitaciones t\u00e9cnicas fuera de nuestro control inmediato.\u003C/p\u003E\n\u003Cp\u003EAdem\u00e1s, puede haber contenido o integraciones heredadas que todav\u00eda no se ajusten plenamente al est\u00e1ndar de accesibilidad seleccionado. Trabajamos activamente para identificar y abordar las barreras de accesibilidad que est\u00e1n bajo nuestro control.\u003C/p\u003E\n\u003Ch2\u003EComentarios y contacto\u003C/h2\u003E\n\u003Cp\u003ESi experimenta alguna dificultad para acceder al contenido de este sitio web o desea informar de un problema de accesibilidad, p\u00f3ngase en contacto con nosotros:\u003C/p\u003E\n\u003Cp\u003ECorreo electr\u00f3nico: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003EAl ponerse en contacto, incluya la URL de la p\u00e1gina espec\u00edfica y una descripci\u00f3n del problema para que podamos investigarlo y responder adecuadamente.\u003C/p\u003E\n\u003Ch2\u003EMejora continua\u003C/h2\u003E\n\u003Cp\u003ELa accesibilidad es un esfuerzo continuo. Revisamos nuestro sitio web de forma peri\u00f3dica y evaluamos oportunidades para mejorar la accesibilidad y la usabilidad.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003E\u00daltima actualizaci\u00f3n: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"totalmente conforme","partially-conformant":"parcialmente conforme","non-conformant":"no conforme","not-assessed":"no accedido"}},"fr":{"template":"\u003Ch2\u003EEngagement en mati\u00e8re d'accessibilit\u00e9\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E s'engage \u00e0 am\u00e9liorer l'accessibilit\u00e9 et l'ergonomie de \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E pour tous les utilisateurs, y compris les personnes en situation de handicap. Nous visons une exp\u00e9rience num\u00e9rique inclusive et travaillons en continu \u00e0 renforcer l'accessibilit\u00e9 de notre site.\u003C/p\u003E\n\u003Ch2\u003ER\u00e9f\u00e9rence de conformit\u00e9 en accessibilit\u00e9\u003C/h2\u003E\n\u003Cp\u003ENous visons l'alignement de notre site sur la norme d'accessibilit\u00e9 \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003ECette r\u00e9f\u00e9rence guide nos actions et nos am\u00e9liorations continues en mati\u00e8re d'accessibilit\u00e9.\u003C/p\u003E\n\u003Ch2\u003EStatut actuel de conformit\u00e9\u003C/h2\u003E\n\u003Cp\u003ESelon notre examen interne, ce site est \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E au regard de \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003ECe statut refl\u00e8te notre \u00e9valuation \u00e0 la date de publication et s'appuie sur notre revue interne et les informations disponibles. L'accessibilit\u00e9 est un processus continu ; les niveaux de conformit\u00e9 peuvent \u00e9voluer au fur et \u00e0 mesure des mises \u00e0 jour.\u003C/p\u003E\n\u003Ch2\u003EFonctionnalit\u00e9s d'accessibilit\u00e9\u003C/h2\u003E\n\u003Cp\u003EPour favoriser l'accessibilit\u00e9, ce site inclut l'interface d'accessibilit\u00e9 AccessYes. Cette interface permet d'ajuster certains param\u00e8tres visuels et ergonomiques selon les besoins individuels, tels que :\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003EAjustements de la taille et de l'espacement du texte\u003C/li\u003E\n\u003Cli\u003EParam\u00e8tres de contraste et de couleur\u003C/li\u003E\n\u003Cli\u003EOutils de surlignage\u003C/li\u003E\n\u003Cli\u003EAutres options d'affichage assist\u00e9\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003ECes outils visent \u00e0 am\u00e9liorer l'exp\u00e9rience utilisateur, mais ne remplacent pas la n\u00e9cessit\u00e9 de contenus accessibles et d'une structure technique ad\u00e9quate du site.\u003C/p\u003E\n\u003Ch2\u003ELimites et consid\u00e9rations techniques\u003C/h2\u003E\n\u003Cp\u003EVeuillez noter ce qui suit :\u003C/p\u003E\n\u003Cp\u003ELa disponibilit\u00e9 et l'efficacit\u00e9 des fonctionnalit\u00e9s d'accessibilit\u00e9 d\u00e9pendent de la configuration du site et de sa maintenance continue.\u003C/p\u003E\n\u003Cp\u003EBien que nous nous efforcions d'assurer l'accessibilit\u00e9 sur \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, certains contenus ou fonctionnalit\u00e9s peuvent ne pas encore satisfaire pleinement les normes d'accessibilit\u00e9 s\u00e9lectionn\u00e9es. Certains contenus peuvent \u00eatre fournis par des tiers ou \u00eatre affect\u00e9s par des contraintes techniques ind\u00e9pendantes de notre contr\u00f4le imm\u00e9diat.\u003C/p\u003E\n\u003Cp\u003EEn outre, certains contenus ou int\u00e9grations h\u00e9rit\u00e9s peuvent ne pas encore \u00eatre enti\u00e8rement align\u00e9s sur la norme d'accessibilit\u00e9 s\u00e9lectionn\u00e9e. Nous \u0153uvrons activement \u00e0 identifier et \u00e0 lever les obstacles \u00e0 l'accessibilit\u00e9 relevant de notre p\u00e9rim\u00e8tre de contr\u00f4le.\u003C/p\u003E\n\u003Ch2\u003ERetours et contact\u003C/h2\u003E\n\u003Cp\u003ESi vous rencontrez des difficult\u00e9s d'acc\u00e8s \u00e0 des contenus sur ce site ou souhaitez signaler un probl\u00e8me d'accessibilit\u00e9, veuillez nous contacter :\u003C/p\u003E\n\u003Cp\u003EE&#8209;mail : \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003ELors de votre prise de contact, veuillez indiquer l'URL de la page concern\u00e9e et une description du probl\u00e8me afin que nous puissions enqu\u00eater et r\u00e9pondre de mani\u00e8re appropri\u00e9e.\u003C/p\u003E\n\u003Ch2\u003EAm\u00e9lioration continue\u003C/h2\u003E\n\u003Cp\u003EL'accessibilit\u00e9 est un effort continu. Nous examinons r\u00e9guli\u00e8rement notre site et \u00e9valuons les possibilit\u00e9s d'am\u00e9liorer l'accessibilit\u00e9 et l'ergonomie.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003EDerni\u00e8re mise \u00e0 jour : {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"pleinement conforme","partially-conformant":"partiellement conforme","non-conformant":"non conforme","not-assessed":"non acc\u00e9d\u00e9"}},"he":{"template":"\u003Ch2\u003E\u05de\u05d7\u05d5\u05d9\u05d1\u05d5\u05ea \u05dc\u05e0\u05d2\u05d9\u05e9\u05d5\u05ea\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E \u05de\u05d7\u05d5\u05d9\u05d1\u05ea \u05dc\u05e9\u05d9\u05e4\u05d5\u05e8 \u05d4\u05e0\u05d2\u05d9\u05e9\u05d5\u05ea \u05d5\u05d4\u05e9\u05d9\u05de\u05d5\u05e9\u05d9\u05d5\u05ea \u05e9\u05dc \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E \u05e2\u05d1\u05d5\u05e8 \u05db\u05dc\u05dc \u05d4\u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd, \u05dc\u05e8\u05d1\u05d5\u05ea \u05d0\u05e0\u05e9\u05d9\u05dd \u05e2\u05dd \u05de\u05d5\u05d2\u05d1\u05dc\u05d5\u05ea. \u05de\u05d8\u05e8\u05ea\u05e0\u05d5 \u05dc\u05e1\u05e4\u05e7 \u05d7\u05d5\u05d5\u05d9\u05d9\u05d4 \u05d3\u05d9\u05d2\u05d9\u05d8\u05dc\u05d9\u05ea \u05de\u05db\u05dc\u05d9\u05dc\u05d4, \u05d5\u05d0\u05e0\u05d5 \u05e4\u05d5\u05e2\u05dc\u05d9\u05dd \u05d1\u05d0\u05d5\u05e4\u05df \u05de\u05ea\u05de\u05e9\u05da \u05dc\u05e9\u05d9\u05e4\u05d5\u05e8 \u05d4\u05e0\u05d2\u05d9\u05e9\u05d5\u05ea \u05d1\u05e8\u05d7\u05d1\u05d9 \u05d4\u05d0\u05ea\u05e8.\u003C/p\u003E\n\u003Ch2\u003E\u05ea\u05e7\u05df \u05e0\u05d2\u05d9\u05e9\u05d5\u05ea \u05d9\u05e2\u05d3\u003C/h2\u003E\n\u003Cp\u003E\u05d0\u05e0\u05d5 \u05e9\u05d5\u05d0\u05e4\u05d9\u05dd \u05dc\u05d9\u05d9\u05e9\u05e8 \u05e7\u05d5 \u05e2\u05dd \u05ea\u05e7\u05df \u05d4\u05e0\u05d2\u05d9\u05e9\u05d5\u05ea \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E \u05d1\u05d0\u05ea\u05e8\u05e0\u05d5.\u003C/p\u003E\n\u003Cp\u003E\u05ea\u05e7\u05df \u05d9\u05e2\u05d3 \u05d6\u05d4 \u05de\u05db\u05d5\u05d5\u05df \u05d0\u05ea \u05de\u05d0\u05de\u05e6\u05d9 \u05d4\u05e0\u05d2\u05d9\u05e9\u05d5\u05ea \u05e9\u05dc\u05e0\u05d5 \u05d5\u05d0\u05ea \u05d4\u05e9\u05d9\u05e4\u05d5\u05e8\u05d9\u05dd \u05d4\u05de\u05ea\u05de\u05e9\u05db\u05d9\u05dd.\u003C/p\u003E\n\u003Ch2\u003E\u05de\u05e6\u05d1 \u05d4\u05ea\u05d0\u05de\u05d4 \u05e0\u05d5\u05db\u05d7\u05d9\u003C/h2\u003E\n\u003Cp\u003E\u05d1\u05d4\u05ea\u05d1\u05e1\u05e1 \u05e2\u05dc \u05d1\u05d3\u05d9\u05e7\u05d4 \u05e4\u05e0\u05d9\u05de\u05d9\u05ea, \u05d0\u05ea\u05e8 \u05d6\u05d4 \u05d4\u05d5\u05d0 \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E \u05d1\u05d9\u05d7\u05e1 \u05dc-\u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003E\u05de\u05e6\u05d1 \u05d6\u05d4 \u05de\u05e9\u05e7\u05e3 \u05d0\u05ea \u05d4\u05e2\u05e8\u05db\u05ea\u05e0\u05d5 \u05d1\u05de\u05d5\u05e2\u05d3 \u05d4\u05e4\u05e8\u05e1\u05d5\u05dd \u05d5\u05de\u05d1\u05d5\u05e1\u05e1 \u05e2\u05dc \u05d1\u05d3\u05d9\u05e7\u05d4 \u05e4\u05e0\u05d9\u05de\u05d9\u05ea \u05d5\u05e2\u05dc \u05de\u05d9\u05d3\u05e2 \u05d6\u05de\u05d9\u05df. \u05e0\u05d2\u05d9\u05e9\u05d5\u05ea \u05d4\u05d9\u05d0 \u05ea\u05d4\u05dc\u05d9\u05da \u05de\u05ea\u05de\u05e9\u05da, \u05d5\u05e8\u05de\u05d5\u05ea \u05d4\u05d4\u05ea\u05d0\u05de\u05d4 \u05e2\u05e9\u05d5\u05d9\u05d5\u05ea \u05dc\u05d4\u05e9\u05ea\u05e0\u05d5\u05ea \u05e2\u05dd \u05d4\u05d8\u05de\u05e2\u05ea \u05e2\u05d3\u05db\u05d5\u05e0\u05d9\u05dd.\u003C/p\u003E\n\u003Ch2\u003E\u05d9\u05db\u05d5\u05dc\u05d5\u05ea \u05e0\u05d2\u05d9\u05e9\u05d5\u05ea\u003C/h2\u003E\n\u003Cp\u003E\u05dc\u05e9\u05dd \u05ea\u05de\u05d9\u05db\u05d4 \u05d1\u05e0\u05d2\u05d9\u05e9\u05d5\u05ea, \u05d1\u05d0\u05ea\u05e8 \u05d6\u05d4 \u05de\u05e9\u05d5\u05dc\u05d1 \u05de\u05de\u05e9\u05e7 \u05d4\u05e0\u05d2\u05d9\u05e9\u05d5\u05ea AccessYes. \u05de\u05de\u05e9\u05e7 \u05d6\u05d4 \u05de\u05d0\u05e4\u05e9\u05e8 \u05dc\u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05dc\u05d4\u05ea\u05d0\u05d9\u05dd \u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05d7\u05d6\u05d5\u05ea\u05d9\u05d5\u05ea \u05d5\u05e9\u05d9\u05de\u05d5\u05e9\u05d9\u05d5\u05ea \u05de\u05e1\u05d5\u05d9\u05de\u05d5\u05ea \u05dc\u05e4\u05d9 \u05e6\u05d5\u05e8\u05db\u05d9\u05d4\u05dd, \u05db\u05d2\u05d5\u05df:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003E\u05d4\u05ea\u05d0\u05de\u05d5\u05ea \u05d2\u05d5\u05d3\u05dc \u05d5\u05e8\u05d9\u05d5\u05d5\u05d7 \u05d8\u05e7\u05e1\u05d8\u003C/li\u003E\n\u003Cli\u003E\u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05e0\u05d9\u05d2\u05d5\u05d3\u05d9\u05d5\u05ea \u05d5\u05e6\u05d1\u05e2\u003C/li\u003E\n\u003Cli\u003E\u05db\u05dc\u05d9 \u05d4\u05d3\u05d2\u05e9\u05d4\u003C/li\u003E\n\u003Cli\u003E\u05d0\u05e4\u05e9\u05e8\u05d5\u05d9\u05d5\u05ea \u05ea\u05e6\u05d5\u05d2\u05d4 \u05de\u05e1\u05d9\u05d9\u05e2\u05d5\u05ea \u05e0\u05d5\u05e1\u05e4\u05d5\u05ea\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003E\u05db\u05dc\u05d9\u05dd \u05d0\u05dc\u05d5 \u05e0\u05d5\u05e2\u05d3\u05d5 \u05dc\u05e9\u05e4\u05e8 \u05d0\u05ea \u05d7\u05d5\u05d5\u05d9\u05d9\u05ea \u05d4\u05e9\u05d9\u05de\u05d5\u05e9, \u05d0\u05da \u05d0\u05d9\u05e0\u05dd \u05de\u05d7\u05dc\u05d9\u05e4\u05d9\u05dd \u05d0\u05ea \u05d4\u05e6\u05d5\u05e8\u05da \u05d1\u05ea\u05d5\u05db\u05df \u05e0\u05d2\u05d9\u05e9 \u05d5\u05d1\u05ea\u05e9\u05ea\u05d9\u05ea \u05d0\u05ea\u05e8 \u05ea\u05e7\u05d9\u05e0\u05d4.\u003C/p\u003E\n\u003Ch2\u003E\u05de\u05d2\u05d1\u05dc\u05d5\u05ea \u05d5\u05e9\u05d9\u05e7\u05d5\u05dc\u05d9\u05dd \u05d8\u05db\u05e0\u05d9\u05d9\u05dd\u003C/h2\u003E\n\u003Cp\u003E\u05dc\u05ea\u05e9\u05d5\u05de\u05ea \u05dc\u05d9\u05d1\u05db\u05dd:\u003C/p\u003E\n\u003Cp\u003E\u05d4\u05d6\u05de\u05d9\u05e0\u05d5\u05ea \u05d5\u05d4\u05d9\u05e2\u05d9\u05dc\u05d5\u05ea \u05e9\u05dc \u05d9\u05db\u05d5\u05dc\u05d5\u05ea \u05d4\u05e0\u05d2\u05d9\u05e9\u05d5\u05ea \u05ea\u05dc\u05d5\u05d9\u05d5\u05ea \u05d1\u05ea\u05e6\u05d5\u05e8\u05ea \u05d4\u05d0\u05ea\u05e8 \u05d5\u05d1\u05ea\u05d7\u05d6\u05d5\u05e7\u05d4 \u05d4\u05e9\u05d5\u05d8\u05e4\u05ea.\u003C/p\u003E\n\u003Cp\u003E\u05dc\u05de\u05e8\u05d5\u05ea \u05de\u05d0\u05de\u05e6\u05d9\u05e0\u05d5 \u05dc\u05d4\u05d1\u05d8\u05d9\u05d7 \u05e0\u05d2\u05d9\u05e9\u05d5\u05ea \u05d1\u05e8\u05d7\u05d1\u05d9 \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, \u05d9\u05d9\u05ea\u05db\u05df \u05e9\u05ea\u05db\u05e0\u05d9\u05dd \u05d0\u05d5 \u05d9\u05db\u05d5\u05dc\u05d5\u05ea \u05de\u05e1\u05d5\u05d9\u05de\u05d9\u05dd \u05e2\u05d3\u05d9\u05d9\u05df \u05d0\u05d9\u05e0\u05dd \u05e2\u05d5\u05de\u05d3\u05d9\u05dd \u05d1\u05de\u05dc\u05d5\u05d0\u05dd \u05d1\u05ea\u05e7\u05e0\u05d9\u05dd \u05e9\u05e0\u05d1\u05d7\u05e8\u05d5. \u05d7\u05dc\u05e7 \u05de\u05d4\u05ea\u05d5\u05db\u05df \u05e2\u05e9\u05d5\u05d9 \u05dc\u05d4\u05d9\u05e0\u05ea\u05df \u05e2\u05dc-\u05d9\u05d3\u05d9 \u05e6\u05d3\u05d3\u05d9\u05dd \u05e9\u05dc\u05d9\u05e9\u05d9\u05d9\u05dd \u05d0\u05d5 \u05dc\u05d4\u05d9\u05d5\u05ea \u05de\u05d5\u05e9\u05e4\u05e2 \u05de\u05de\u05d2\u05d1\u05dc\u05d5\u05ea \u05d8\u05db\u05e0\u05d9\u05d5\u05ea \u05e9\u05d0\u05d9\u05e0\u05df \u05d1\u05e9\u05dc\u05d9\u05d8\u05ea\u05e0\u05d5 \u05d4\u05de\u05d9\u05d9\u05d3\u05d9\u05ea.\u003C/p\u003E\n\u003Cp\u003E\u05d1\u05e0\u05d5\u05e1\u05e3, \u05d9\u05d9\u05ea\u05db\u05df \u05e9\u05ea\u05d5\u05db\u05df \u05d0\u05d5 \u05de\u05de\u05e9\u05e7\u05d9\u05dd \u05d5\u05ea\u05d9\u05e7\u05d9\u05dd \u05e2\u05d3\u05d9\u05d9\u05df \u05d0\u05d9\u05e0\u05dd \u05de\u05d9\u05d5\u05e9\u05e8\u05d9\u05dd \u05d1\u05de\u05dc\u05d5\u05d0\u05dd \u05dc\u05ea\u05e7\u05df \u05d4\u05e0\u05d2\u05d9\u05e9\u05d5\u05ea \u05d4\u05e0\u05d1\u05d7\u05e8. \u05d0\u05e0\u05d5 \u05e4\u05d5\u05e2\u05dc\u05d9\u05dd \u05d1\u05d0\u05d5\u05e4\u05df \u05e4\u05e2\u05d9\u05dc \u05dc\u05d6\u05d4\u05d5\u05ea \u05d5\u05dc\u05d8\u05e4\u05dc \u05d1\u05d7\u05e1\u05de\u05d9 \u05e0\u05d2\u05d9\u05e9\u05d5\u05ea \u05d4\u05e0\u05de\u05e6\u05d0\u05d9\u05dd \u05d1\u05e9\u05dc\u05d9\u05d8\u05ea\u05e0\u05d5.\u003C/p\u003E\n\u003Ch2\u003E\u05de\u05e9\u05d5\u05d1 \u05d5\u05d9\u05e6\u05d9\u05e8\u05ea \u05e7\u05e9\u05e8\u003C/h2\u003E\n\u003Cp\u003E\u05d0\u05dd \u05d0\u05ea\u05dd \u05e0\u05ea\u05e7\u05dc\u05d9\u05dd \u05d1\u05e7\u05d5\u05e9\u05d9 \u05d1\u05d2\u05d9\u05e9\u05d4 \u05dc\u05ea\u05d5\u05db\u05df \u05d1\u05d0\u05ea\u05e8 \u05d6\u05d4 \u05d0\u05d5 \u05de\u05e2\u05d5\u05e0\u05d9\u05d9\u05e0\u05d9\u05dd \u05dc\u05d3\u05d5\u05d5\u05d7 \u05e2\u05dc \u05d1\u05e2\u05d9\u05d9\u05ea \u05e0\u05d2\u05d9\u05e9\u05d5\u05ea, \u05d0\u05e0\u05d0 \u05e6\u05e8\u05d5 \u05e7\u05e9\u05e8:\u003C/p\u003E\n\u003Cp\u003E\u05d3\u05d5\u05d0\u05f4\u05dc: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003E\u05d1\u05e2\u05ea \u05d4\u05e4\u05e0\u05d9\u05d9\u05d4, \u05e6\u05d9\u05d9\u05e0\u05d5 \u05d0\u05ea \u05db\u05ea\u05d5\u05d1\u05ea \u05d4-URL \u05e9\u05dc \u05d4\u05e2\u05de\u05d5\u05d3 \u05d4\u05e8\u05dc\u05d5\u05d5\u05e0\u05d8\u05d9 \u05d5\u05ea\u05d9\u05d0\u05d5\u05e8 \u05d4\u05d1\u05e2\u05d9\u05d4 \u05db\u05d3\u05d9 \u05e9\u05e0\u05d5\u05db\u05dc \u05dc\u05d1\u05d3\u05d5\u05e7 \u05d5\u05dc\u05e4\u05e2\u05d5\u05dc \u05d1\u05d4\u05ea\u05d0\u05dd.\u003C/p\u003E\n\u003Ch2\u003E\u05e9\u05d9\u05e4\u05d5\u05e8 \u05de\u05ea\u05de\u05e9\u05da\u003C/h2\u003E\n\u003Cp\u003E\u05d4\u05e0\u05d2\u05d9\u05e9\u05d5\u05ea \u05d4\u05d9\u05d0 \u05de\u05d0\u05de\u05e5 \u05de\u05ea\u05de\u05e9\u05da. \u05d0\u05e0\u05d5 \u05d1\u05d5\u05d7\u05e0\u05d9\u05dd \u05d0\u05ea \u05d0\u05ea\u05e8\u05e0\u05d5 \u05d1\u05d0\u05d5\u05e4\u05df \u05e7\u05d1\u05d5\u05e2 \u05d5\u05de\u05e2\u05e8\u05d9\u05db\u05d9\u05dd \u05d4\u05d6\u05d3\u05de\u05e0\u05d5\u05d9\u05d5\u05ea \u05dc\u05e9\u05d9\u05e4\u05d5\u05e8 \u05d4\u05e0\u05d2\u05d9\u05e9\u05d5\u05ea \u05d5\u05d4\u05e9\u05d9\u05de\u05d5\u05e9\u05d9\u05d5\u05ea.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003E\u05ea\u05d0\u05e8\u05d9\u05da \u05e2\u05d3\u05db\u05d5\u05df \u05d0\u05d7\u05e8\u05d5\u05df: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"\u05ea\u05d5\u05d0\u05dd \u05d1\u05de\u05dc\u05d5\u05d0\u05d5","partially-conformant":"\u05ea\u05d5\u05d0\u05dd \u05d7\u05dc\u05e7\u05d9\u05ea","non-conformant":"\u05d0\u05d9\u05e0\u05d5 \u05ea\u05d5\u05d0\u05dd","not-assessed":"\u05dc\u05d0 \u05d1\u05d5\u05e6\u05e2\u05d4 \u05d2\u05d9\u05e9\u05d4"}},"hr":{"template":"\u003Ch2\u003EObveza u pogledu pristupa\u010dnosti\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E posve\u0107uje se pobolj\u0161anju pristupa\u010dnosti i upotrebljivosti stranice \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E za sve korisnike, uklju\u010duju\u0107i osobe s invaliditetom. Cilj nam je pru\u017eiti uklju\u010divo digitalno iskustvo te kontinuirano radimo na unaprje\u0111enju pristupa\u010dnosti na\u0161e web-stranice.\u003C/p\u003E\n\u003Ch2\u003ECiljani standard pristupa\u010dnosti\u003C/h2\u003E\n\u003Cp\u003ENastojimo uskladiti na\u0161u web-stranicu sa standardom pristupa\u010dnosti \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EOvaj ciljani standard usmjerava na\u0161e napore i stalna pobolj\u0161anja u podru\u010dju pristupa\u010dnosti.\u003C/p\u003E\n\u003Ch2\u003ETrenuta\u010dni status uskla\u0111enosti\u003C/h2\u003E\n\u003Cp\u003ENa temelju na\u0161e interne provjere, ova je stranica \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E u odnosu na \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EOvaj status odra\u017eava na\u0161u procjenu u trenutku objave te se temelji na internoj provjeri i raspolo\u017eivim informacijama. Pristupa\u010dnost je stalan proces, a razine uskla\u0111enosti mogu se mijenjati kako se provode nadogradnje.\u003C/p\u003E\n\u003Ch2\u003EZna\u010dajke pristupa\u010dnosti\u003C/h2\u003E\n\u003Cp\u003ERadi potpore pristupa\u010dnosti, ova web-stranica uklju\u010duje AccessYes su\u010delje za pristupa\u010dnost. Ovo su\u010delje omogu\u0107uje korisnicima prilagodbu odre\u0111enih vizualnih i uporabnih postavki prema individualnim potrebama, kao \u0161to su:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003EPrilagodbe veli\u010dine i razmaka teksta\u003C/li\u003E\n\u003Cli\u003EPostavke kontrasta i boja\u003C/li\u003E\n\u003Cli\u003EAlati za isticanje\u003C/li\u003E\n\u003Cli\u003EDruge mogu\u0107nosti potpomognutog prikaza\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003EOvi alati namijenjeni su pobolj\u0161anju korisni\u010dkog iskustva, ali ne zamjenjuju potrebu za pristupa\u010dnim sadr\u017eajem i odgovaraju\u0107om tehni\u010dkom strukturom web-stranice.\u003C/p\u003E\n\u003Ch2\u003EOgrani\u010denja i tehni\u010dka razmatranja\u003C/h2\u003E\n\u003Cp\u003EImajte na umu sljede\u0107e:\u003C/p\u003E\n\u003Cp\u003EDostupnost i u\u010dinkovitost zna\u010dajki pristupa\u010dnosti ovise o konfiguraciji web-stranice i kontinuiranom odr\u017eavanju.\u003C/p\u003E\n\u003Cp\u003EIako nastojimo osigurati pristupa\u010dnost u okviru \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, pojedini sadr\u017eaji ili zna\u010dajke mo\u017eda jo\u0161 uvijek ne ispunjavaju u potpunosti odabrane standarde pristupa\u010dnosti. Neke sadr\u017eaje mogu pru\u017eati tre\u0107e strane ili ih mogu ograni\u010davati tehni\u010dka ograni\u010denja izvan na\u0161e neposredne kontrole.\u003C/p\u003E\n\u003Cp\u003EDodatno, mo\u017ee postojati odre\u0111eni naslije\u0111eni sadr\u017eaj ili integracije koje jo\u0161 nisu u potpunosti uskla\u0111ene s odabranim standardom. Aktivno radimo na prepoznavanju i uklanjanju prepreka pristupa\u010dnosti koje su u okviru na\u0161e nadle\u017enosti.\u003C/p\u003E\n\u003Ch2\u003EPovratne informacije i kontakt\u003C/h2\u003E\n\u003Cp\u003EAko imate pote\u0161ko\u0107a s pristupom sadr\u017eaju na ovoj stranici ili \u017eelite prijaviti problem s pristupa\u010dno\u0161\u0107u, kontaktirajte nas:\u003C/p\u003E\n\u003Cp\u003EE&#8209;po\u0161ta: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003EPri kontaktu navedite URL odre\u0111ene stranice i opis problema kako bismo ga mogli istra\u017eiti i primjereno odgovoriti.\u003C/p\u003E\n\u003Ch2\u003EStalno pobolj\u0161avanje\u003C/h2\u003E\n\u003Cp\u003EPristupa\u010dnost je kontinuiran napor. Redovito pregledavamo na\u0161u web-stranicu i procjenjujemo mogu\u0107nosti za pobolj\u0161anje pristupa\u010dnosti i upotrebljivosti.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003EZadnje a\u017euriranje: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"potpuno uskla\u0111eno","partially-conformant":"djelomi\u010dno uskla\u0111eno","non-conformant":"neuskla\u0111eno","not-assessed":"nije pristupljeno"}},"hu":{"template":"\u003Ch2\u003EElk\u00f6telez\u0151d\u00e9s az akad\u00e1lymentess\u00e9g mellett\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E elk\u00f6telezett a(z) \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E akad\u00e1lymentess\u00e9g\u00e9nek \u00e9s haszn\u00e1lhat\u00f3s\u00e1g\u00e1nak jav\u00edt\u00e1sa mellett minden felhaszn\u00e1l\u00f3 \u2014 k\u00f6zt\u00fck fogyat\u00e9koss\u00e1ggal \u00e9l\u0151 szem\u00e9lyek \u2014 sz\u00e1m\u00e1ra. C\u00e9lunk egy befogad\u00f3 digit\u00e1lis \u00e9lm\u00e9ny, \u00e9s folyamatosan dolgozunk webhely\u00fcnk akad\u00e1lymentess\u00e9g\u00e9nek fejleszt\u00e9s\u00e9n.\u003C/p\u003E\n\u003Ch2\u003EC\u00e9lk\u00e9nt kit\u0171z\u00f6tt akad\u00e1lymentess\u00e9gi szabv\u00e1ny\u003C/h2\u003E\n\u003Cp\u003ET\u00f6reksz\u00fcnk arra, hogy webhely\u00fcnket a \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E akad\u00e1lymentess\u00e9gi szabv\u00e1nnyal \u00f6sszhangba hozzuk.\u003C/p\u003E\n\u003Cp\u003EEz a c\u00e9l-szabv\u00e1ny ir\u00e1nyt mutat akad\u00e1lymentess\u00e9gi er\u0151fesz\u00edt\u00e9seinknek \u00e9s folyamatos fejleszt\u00e9seinknek.\u003C/p\u003E\n\u003Ch2\u003EJelenlegi megfelel\u0151s\u00e9gi \u00e1llapot\u003C/h2\u003E\n\u003Cp\u003EBels\u0151 vizsg\u00e1latunk alapj\u00e1n ez a webhely \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E a(z) \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E tekintet\u00e9ben.\u003C/p\u003E\n\u003Cp\u003EEz az \u00e1llapot a k\u00f6zz\u00e9t\u00e9tel id\u0151pontj\u00e1ban v\u00e9gzett \u00e9rt\u00e9kel\u00e9s\u00fcnket t\u00fckr\u00f6zi, \u00e9s bels\u0151 fel\u00fclvizsg\u00e1latunkon, valamint a rendelkez\u00e9sre \u00e1ll\u00f3 inform\u00e1ci\u00f3kon alapul. Az akad\u00e1lymentess\u00e9g folyamatos folyamat; a megfelel\u0151s\u00e9gi szintek a friss\u00edt\u00e9sek bevezet\u00e9s\u00e9vel v\u00e1ltozhatnak.\u003C/p\u003E\n\u003Ch2\u003EAkad\u00e1lymentess\u00e9gi funkci\u00f3k\u003C/h2\u003E\n\u003Cp\u003EAz akad\u00e1lymentess\u00e9g t\u00e1mogat\u00e1sa \u00e9rdek\u00e9ben ez a webhely tartalmazza az AccessYes akad\u00e1lymentess\u00e9gi fel\u00fcletet. Ez a fel\u00fclet lehet\u0151v\u00e9 teszi bizonyos vizu\u00e1lis \u00e9s haszn\u00e1lhat\u00f3s\u00e1gi be\u00e1ll\u00edt\u00e1sok egy\u00e9ni ig\u00e9nyek szerinti m\u00f3dos\u00edt\u00e1s\u00e1t, p\u00e9ld\u00e1ul:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003ESz\u00f6vegm\u00e9ret \u00e9s t\u00e9rk\u00f6z\u00f6k be\u00e1ll\u00edt\u00e1sa\u003C/li\u003E\n\u003Cli\u003EKontrast- \u00e9s sz\u00ednbe\u00e1ll\u00edt\u00e1sok\u003C/li\u003E\n\u003Cli\u003EKiemel\u0151 eszk\u00f6z\u00f6k\u003C/li\u003E\n\u003Cli\u003EEgy\u00e9b, a megjelen\u00edt\u00e9st seg\u00edt\u0151 opci\u00f3k\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003EEzek az eszk\u00f6z\u00f6k a felhaszn\u00e1l\u00f3i \u00e9lm\u00e9ny jav\u00edt\u00e1s\u00e1t szolg\u00e1lj\u00e1k, de nem helyettes\u00edtik a hozz\u00e1f\u00e9rhet\u0151 tartalmat \u00e9s a megfelel\u0151 technikai webhely-strukt\u00far\u00e1t.\u003C/p\u003E\n\u003Ch2\u003EKorl\u00e1tok \u00e9s m\u0171szaki szempontok\u003C/h2\u003E\n\u003Cp\u003EK\u00e9rj\u00fck, vegye figyelembe az al\u00e1bbiakat:\u003C/p\u003E\n\u003Cp\u003EAz akad\u00e1lymentess\u00e9gi funkci\u00f3k el\u00e9rhet\u0151s\u00e9ge \u00e9s hat\u00e9konys\u00e1ga a webhely konfigur\u00e1ci\u00f3j\u00e1t\u00f3l \u00e9s a folyamatos karbantart\u00e1st\u00f3l f\u00fcgg.\u003C/p\u003E\n\u003Cp\u003EB\u00e1r t\u00f6reksz\u00fcnk a \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E teljes k\u00f6r\u0171 akad\u00e1lymentess\u00e9g\u00e9re, el\u0151fordulhat, hogy egyes tartalmak vagy funkci\u00f3k m\u00e9g nem felelnek meg marad\u00e9ktalanul a kiv\u00e1lasztott szabv\u00e1nyoknak. Egyes tartalmakat harmadik felek biztos\u00edtanak, vagy olyan m\u0171szaki korl\u00e1tok \u00e9rintik \u0151ket, amelyek k\u00edv\u00fcl esnek k\u00f6zvetlen ellen\u0151rz\u00e9s\u00fcnk\u00f6n.\u003C/p\u003E\n\u003Cp\u003ETov\u00e1bb\u00e1 lehetnek r\u00e9gi tartalmak vagy integr\u00e1ci\u00f3k, amelyek m\u00e9g nem teljes m\u00e9rt\u00e9kben igazodnak a kiv\u00e1lasztott szabv\u00e1nyhoz. Akt\u00edvan dolgozunk az ellen\u0151rz\u00e9s\u00fcnk alatt \u00e1ll\u00f3 akad\u00e1lymentess\u00e9gi akad\u00e1lyok azonos\u00edt\u00e1s\u00e1n \u00e9s megsz\u00fcntet\u00e9s\u00e9n.\u003C/p\u003E\n\u003Ch2\u003EVisszajelz\u00e9s \u00e9s kapcsolat\u003C/h2\u003E\n\u003Cp\u003EAmennyiben neh\u00e9zs\u00e9get tapasztal a webhely tartalm\u00e1hoz val\u00f3 hozz\u00e1f\u00e9r\u00e9sben, vagy akad\u00e1lymentess\u00e9gi probl\u00e9m\u00e1t szeretne jelezni, k\u00e9rj\u00fck, l\u00e9pjen kapcsolatba vel\u00fcnk:\u003C/p\u003E\n\u003Cp\u003EE&#8209;mail: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003EK\u00e9rj\u00fck, a megkeres\u00e9sben t\u00fcntesse fel az \u00e9rintett oldal URL-j\u00e9t \u00e9s a probl\u00e9ma le\u00edr\u00e1s\u00e1t, hogy kivizsg\u00e1lhassuk \u00e9s megfelel\u0151en reag\u00e1lhassunk.\u003C/p\u003E\n\u003Ch2\u003EFolyamatos fejleszt\u00e9s\u003C/h2\u003E\n\u003Cp\u003EAz akad\u00e1lymentess\u00e9g folyamatos t\u00f6rekv\u00e9s. Rendszeresen fel\u00fclvizsg\u00e1ljuk webhely\u00fcnket \u00e9s \u00e9rt\u00e9kelj\u00fck a fejleszt\u00e9si lehet\u0151s\u00e9geket az akad\u00e1lymentess\u00e9g \u00e9s a haszn\u00e1lhat\u00f3s\u00e1g jav\u00edt\u00e1sa \u00e9rdek\u00e9ben.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003EUtolj\u00e1ra friss\u00edtve: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"teljes m\u00e9rt\u00e9kben megfelel","partially-conformant":"r\u00e9szben megfelel","non-conformant":"nem felel meg","not-assessed":"nem t\u00f6rt\u00e9nt el\u00e9r\u00e9s"}},"it":{"template":"\u003Ch2\u003EImpegno per l'accessibilit\u00e0\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E si impegna a migliorare l'accessibilit\u00e0 e l'usabilit\u00e0 di \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E per tutti gli utenti, comprese le persone con disabilit\u00e0. Miriamo a offrire un'esperienza digitale inclusiva e lavoriamo costantemente per migliorare l'accessibilit\u00e0 del nostro sito.\u003C/p\u003E\n\u003Ch2\u003EStandard di accessibilit\u00e0 di riferimento\u003C/h2\u003E\n\u003Cp\u003EMiriamo ad allineare il nostro sito web allo standard di accessibilit\u00e0 \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EQuesto standard di riferimento guida i nostri sforzi e i miglioramenti continui in materia di accessibilit\u00e0.\u003C/p\u003E\n\u003Ch2\u003EStato attuale di conformit\u00e0\u003C/h2\u003E\n\u003Cp\u003EIn base alla nostra revisione interna, questo sito web \u00e8 \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E rispetto a \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EQuesto stato riflette la nostra valutazione al momento della pubblicazione ed \u00e8 basato sulla nostra revisione interna e sulle informazioni disponibili. L'accessibilit\u00e0 \u00e8 un processo continuo e i livelli di conformit\u00e0 possono evolvere man mano che vengono implementati aggiornamenti.\u003C/p\u003E\n\u003Ch2\u003EFunzionalit\u00e0 di accessibilit\u00e0\u003C/h2\u003E\n\u003Cp\u003EPer supportare l'accessibilit\u00e0, questo sito include l'interfaccia di accessibilit\u00e0 AccessYes. Questa interfaccia consente agli utenti di regolare alcune impostazioni visive e di usabilit\u00e0 in base alle esigenze individuali, ad esempio:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003ERegolazioni della dimensione e della spaziatura del testo\u003C/li\u003E\n\u003Cli\u003EImpostazioni di contrasto e colore\u003C/li\u003E\n\u003Cli\u003EStrumenti di evidenziazione\u003C/li\u003E\n\u003Cli\u003EAltre opzioni di visualizzazione assistita\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003EQuesti strumenti sono pensati per migliorare l'esperienza d'uso, ma non sostituiscono la necessit\u00e0 di contenuti accessibili e di una corretta struttura tecnica del sito.\u003C/p\u003E\n\u003Ch2\u003ELimitazioni e considerazioni tecniche\u003C/h2\u003E\n\u003Cp\u003ESi prega di notare quanto segue:\u003C/p\u003E\n\u003Cp\u003ELa disponibilit\u00e0 e l'efficacia delle funzionalit\u00e0 di accessibilit\u00e0 dipendono dalla configurazione del sito e dalla manutenzione continua.\u003C/p\u003E\n\u003Cp\u003ESebbene ci impegniamo a garantire l'accessibilit\u00e0 su \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, alcuni contenuti o funzionalit\u00e0 potrebbero non soddisfare ancora pienamente gli standard di accessibilit\u00e0 selezionati. Alcuni contenuti possono essere forniti da terze parti o essere influenzati da vincoli tecnici al di fuori del nostro controllo immediato.\u003C/p\u003E\n\u003Cp\u003EInoltre, potrebbero esserci contenuti o integrazioni legacy che non sono ancora pienamente allineati allo standard di accessibilit\u00e0 selezionato. Lavoriamo attivamente per individuare e affrontare le barriere all'accessibilit\u00e0 che rientrano nel nostro controllo.\u003C/p\u003E\n\u003Ch2\u003EFeedback e contatti\u003C/h2\u003E\n\u003Cp\u003ESe riscontra difficolt\u00e0 ad accedere ai contenuti di questo sito o desidera segnalare un problema di accessibilit\u00e0, ci contatti:\u003C/p\u003E\n\u003Cp\u003EE&#8209;mail: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003EQuando ci contatta, includa l'URL della pagina specifica e una descrizione del problema, cos\u00ec da consentirci di indagare e rispondere in modo adeguato.\u003C/p\u003E\n\u003Ch2\u003EMiglioramento continuo\u003C/h2\u003E\n\u003Cp\u003EL'accessibilit\u00e0 \u00e8 un impegno continuo. Esaminiamo regolarmente il nostro sito e valutiamo opportunit\u00e0 per migliorare accessibilit\u00e0 e usabilit\u00e0.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003EUltimo aggiornamento: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"pienamente conforme","partially-conformant":"parzialmente conforme","non-conformant":"non conforme","not-assessed":"non accesso"}},"lt":{"template":"\u003Ch2\u003E\u012esipareigojimas d\u0117l prieinamumo\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E \u012fsipareigoja gerinti \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E prieinamum\u0105 ir patogum\u0105 visiems naudotojams, \u012fskaitant \u017emones su negalia. Siekiame suteikti \u012ftrauk\u0173 skaitmenin\u012f patyrim\u0105 ir nuolat dirbame, kad gerintume prieinamum\u0105 visoje m\u016bs\u0173 svetain\u0117je.\u003C/p\u003E\n\u003Ch2\u003ETikslinis prieinamumo standartas\u003C/h2\u003E\n\u003Cp\u003ESiekime suderinti m\u016bs\u0173 svetain\u0119 su \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E prieinamumo standartu.\u003C/p\u003E\n\u003Cp\u003E\u0160is tikslinis standartas nukreipia m\u016bs\u0173 pastangas ir nuolatin\u012f tobulinim\u0105 prieinamumo srityje.\u003C/p\u003E\n\u003Ch2\u003EDabartinis atitikties statusas\u003C/h2\u003E\n\u003Cp\u003ERemiantis m\u016bs\u0173 vidine per\u017ei\u016bra, \u0161i svetain\u0117 yra \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E pagal \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003E\u0160is statusas atspindi m\u016bs\u0173 vertinim\u0105 paskelbimo metu ir grind\u017eiamas vidine per\u017ei\u016bra bei turima informacija. Prieinamumas yra nuolatinis procesas, tod\u0117l atitikties lygiai gali kisti, kai diegiami atnaujinimai.\u003C/p\u003E\n\u003Ch2\u003EPrieinamumo funkcijos\u003C/h2\u003E\n\u003Cp\u003E\u0160ioje svetain\u0117je naudojama \u201eAccessYes\" prieinamumo s\u0105saja. \u0160i s\u0105saja leid\u017eia naudotojams pritaikyti tam tikrus vaizdinius ir naudotoji\u0161kus nustatymus pagal individualius poreikius, pavyzd\u017eiui:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003ETeksto dyd\u017eio ir tarp\u0173 reguliavim\u0105\u003C/li\u003E\n\u003Cli\u003EKontrasto ir spalv\u0173 nustatymus\u003C/li\u003E\n\u003Cli\u003EPary\u0161kinimo \u012frankius\u003C/li\u003E\n\u003Cli\u003EKitas pagalbin\u0117s per\u017ei\u016bros parinktis\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003E\u0160ie \u012frankiai skirti pagerinti naudotojo patirt\u012f, ta\u010diau jie nepakei\u010dia prieinamo turinio ir tinkamos svetain\u0117s strukt\u016bros poreikio.\u003C/p\u003E\n\u003Ch2\u003EApribojimai ir techniniai aspektai\u003C/h2\u003E\n\u003Cp\u003EAtkreipkite d\u0117mes\u012f \u012f toliau pateikt\u0105 informacij\u0105:\u003C/p\u003E\n\u003Cp\u003EPrieinamumo funkcij\u0173 prieinamumas ir veiksmingumas priklauso nuo svetain\u0117s konfig\u016bracijos ir nuolatin\u0117s prie\u017ei\u016bros.\u003C/p\u003E\n\u003Cp\u003ENors dedame pastangas u\u017etikrinti prieinamum\u0105 \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, dalis turinio ar funkcij\u0173 gali dar neatitikti pasirinkt\u0173 prieinamumo standart\u0173. Dalis turinio gali b\u016bti tre\u010di\u0173j\u0173 \u0161ali\u0173 arba priklausyti nuo technini\u0173 apribojim\u0173, kuri\u0173 tiesiogiai nekontroliuojame.\u003C/p\u003E\n\u003Cp\u003EBe to, gali b\u016bti paveld\u0117to turinio ar integracij\u0173, kurios dar nevisi\u0161kai atitinka pasirinkt\u0105 prieinamumo standart\u0105. Aktyviai dirbame, kad atpa\u017eintume ir pa\u0161alintume m\u016bs\u0173 kontroliuojamas prieinamumo kli\u016btis.\u003C/p\u003E\n\u003Ch2\u003EAtsiliepimai ir kontaktai\u003C/h2\u003E\n\u003Cp\u003EJei patiriate sunkum\u0173 pasiekiant turin\u012f \u0161ioje svetain\u0117je arba norite prane\u0161ti apie prieinamumo problem\u0105, susisiekite su mumis:\u003C/p\u003E\n\u003Cp\u003EEl. pa\u0161tas: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003EKreipdamiesi nurodykite konkretaus puslapio URL ir problemos apra\u0161ym\u0105, kad gal\u0117tume tinkamai i\u0161tirti ir atsakyti.\u003C/p\u003E\n\u003Ch2\u003ENuolatinis tobulinimas\u003C/h2\u003E\n\u003Cp\u003EPrieinamumas \u2013 tai nuolatin\u0117s pastangos. Reguliariai per\u017ei\u016brime savo svetain\u0119 ir vertiname galimybes gerinti prieinamum\u0105 ir patogum\u0105.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003EPaskutin\u012f kart\u0105 atnaujinta: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"visi\u0161kai atitinkantis","partially-conformant":"i\u0161 dalies atitinkantis","non-conformant":"neatitinkantis","not-assessed":"nepasiektas"}},"ml":{"template":"\u003Ch2\u003E\u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24\u0d2f\u0d3f\u0d32\u0d47\u0d15\u0d4d\u0d15\u0d41\u0d33\u0d4d\u0d33 \u0d2a\u0d4d\u0d30\u0d24\u0d3f\u0d2c\u0d26\u0d4d\u0d27\u0d24\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E \u0d0e\u0d28\u0d4d\u0d28 \u0d35\u0d46\u0d2c\u0d4d\u0d38\u0d48\u0d31\u0d4d\u0d31\u0d3f\u0d28\u0d4d\u0d31\u0d46 \u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24\u0d2f\u0d41\u0d02 \u0d09\u0d2a\u0d2f\u0d4b\u0d17\u0d2a\u0d4d\u0d30\u0d3e\u0d2f\u0d4b\u0d17\u0d3f\u0d15\u0d24\u0d2f\u0d41\u0d02 \u0d0e\u0d32\u0d4d\u0d32\u0d3e \u0d09\u0d2a\u0d2f\u0d4b\u0d15\u0d4d\u0d24\u0d3e\u0d15\u0d4d\u0d15\u0d7e\u0d15\u0d4d\u0d15\u0d41\u0d02, \u0d2d\u0d3f\u0d28\u0d4d\u0d28\u0d36\u0d47\u0d37\u0d3f\u0d2f\u0d41\u0d33\u0d4d\u0d33\u0d35\u0d30\u0d46\u0d2f\u0d41\u0d02 \u0d09\u0d7e\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d46, \u0d2e\u0d46\u0d1a\u0d4d\u0d1a\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24\u0d41\u0d28\u0d4d\u0d28\u0d24\u0d3f\u0d28\u0d4d \u0d2a\u0d4d\u0d30\u0d24\u0d3f\u0d2c\u0d26\u0d4d\u0d27\u0d30\u0d3e\u0d23\u0d4d. \u0d09\u0d7e\u0d15\u0d4d\u0d15\u0d4a\u0d33\u0d4d\u0d33\u0d41\u0d28\u0d4d\u0d28 \u0d12\u0d30\u0d41 \u0d21\u0d3f\u0d1c\u0d3f\u0d31\u0d4d\u0d31\u0d7d \u0d05\u0d28\u0d41\u0d2d\u0d35\u0d02 \u0d28\u0d7d\u0d15\u0d41\u0d15\u0d2f\u0d46\u0d28\u0d4d\u0d28\u0d24\u0d3e\u0d23\u0d4d \u0d1e\u0d19\u0d4d\u0d19\u0d33\u0d41\u0d1f\u0d46 \u0d32\u0d15\u0d4d\u0d37\u0d4d\u0d2f\u0d02; \u0d35\u0d46\u0d2c\u0d4d\u0d38\u0d48\u0d31\u0d4d\u0d31\u0d3f\u0d32\u0d41\u0d1f\u0d28\u0d40\u0d33\u0d02 \u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24 \u0d2e\u0d46\u0d1a\u0d4d\u0d1a\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24\u0d41\u0d28\u0d4d\u0d28\u0d24\u0d3f\u0d28\u0d3e\u0d2f\u0d3f \u0d1e\u0d19\u0d4d\u0d19\u0d7e \u0d24\u0d41\u0d1f\u0d7c\u0d1a\u0d4d\u0d1a\u0d2f\u0d3e\u0d2f\u0d3f \u0d2a\u0d4d\u0d30\u0d35\u0d7c\u0d24\u0d4d\u0d24\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d41.\u003C/p\u003E\n\u003Ch2\u003E\u0d32\u0d15\u0d4d\u0d37\u0d4d\u0d2f\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d4d\u0d1f \u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24\u0d3e \u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d7b\u0d21\u0d47\u0d21\u0d4d\u003C/h2\u003E\n\u003Cp\u003E\u0d1e\u0d19\u0d4d\u0d19\u0d33\u0d41\u0d1f\u0d46 \u0d35\u0d46\u0d2c\u0d4d\u0d38\u0d48\u0d31\u0d4d\u0d31\u0d4d \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E \u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24\u0d3e \u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d7b\u0d21\u0d47\u0d21\u0d3f\u0d28\u0d4b\u0d1f\u0d4d \u0d2a\u0d4a\u0d30\u0d41\u0d24\u0d4d\u0d24\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24\u0d41\u0d15\u0d2f\u0d46\u0d28\u0d4d\u0d28\u0d24\u0d3e\u0d23\u0d4d \u0d1e\u0d19\u0d4d\u0d19\u0d33\u0d41\u0d1f\u0d46 \u0d32\u0d15\u0d4d\u0d37\u0d4d\u0d2f\u0d02.\u003C/p\u003E\n\u003Cp\u003E\u0d08 \u0d32\u0d15\u0d4d\u0d37\u0d4d\u0d2f \u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d7b\u0d21\u0d47\u0d21\u0d4d \u0d1e\u0d19\u0d4d\u0d19\u0d33\u0d41\u0d1f\u0d46 \u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24\u0d3e \u0d36\u0d4d\u0d30\u0d2e\u0d19\u0d4d\u0d19\u0d7e\u0d15\u0d4d\u0d15\u0d41\u0d02 \u0d24\u0d41\u0d1f\u0d7c\u0d1a\u0d4d\u0d1a\u0d2f\u0d3e\u0d2f \u0d2e\u0d46\u0d1a\u0d4d\u0d1a\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24\u0d32\u0d41\u0d15\u0d7e\u0d15\u0d4d\u0d15\u0d41\u0d02 \u0d26\u0d3f\u0d36\u0d3e\u0d2c\u0d4b\u0d27\u0d02 \u0d28\u0d7d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d41.\u003C/p\u003E\n\u003Ch2\u003E\u0d28\u0d3f\u0d32\u0d35\u0d3f\u0d32\u0d46 \u0d05\u0d28\u0d41\u0d38\u0d30\u0d23 \u0d28\u0d3f\u0d32\u003C/h2\u003E\n\u003Cp\u003E\u0d1e\u0d19\u0d4d\u0d19\u0d33\u0d41\u0d1f\u0d46 \u0d06\u0d2d\u0d4d\u0d2f\u0d28\u0d4d\u0d24\u0d30 \u0d05\u0d35\u0d32\u0d4b\u0d15\u0d28\u0d24\u0d4d\u0d24\u0d3f\u0d28\u0d4d\u0d31\u0d46 \u0d05\u0d1f\u0d3f\u0d38\u0d4d\u0d25\u0d3e\u0d28\u0d24\u0d4d\u0d24\u0d3f\u0d7d, \u0d08 \u0d35\u0d46\u0d2c\u0d4d\u0d38\u0d48\u0d31\u0d4d\u0d31\u0d4d \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E \u0d0e\u0d28\u0d4d\u0d28\u0d24\u0d3f\u0d28\u0d4b\u0d1f\u0d4d \u0d2c\u0d28\u0d4d\u0d27\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d4d\u0d1f\u0d41\u0d35\u0d46\u0d1a\u0d4d\u0d1a\u0d3e\u0d7d \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E \u0d06\u0d23\u0d4d.\u003C/p\u003E\n\u003Cp\u003E\u0d08 \u0d28\u0d3f\u0d32 \u0d2a\u0d4d\u0d30\u0d38\u0d3f\u0d26\u0d4d\u0d27\u0d40\u0d15\u0d30\u0d23 \u0d38\u0d2e\u0d2f\u0d24\u0d4d\u0d24\u0d46 \u0d1e\u0d19\u0d4d\u0d19\u0d33\u0d41\u0d1f\u0d46 \u0d35\u0d3f\u0d32\u0d2f\u0d3f\u0d30\u0d41\u0d24\u0d4d\u0d24\u0d32\u0d3f\u0d28\u0d46 \u0d2a\u0d4d\u0d30\u0d24\u0d3f\u0d2b\u0d32\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d24\u0d41\u0d02 \u0d06\u0d2d\u0d4d\u0d2f\u0d28\u0d4d\u0d24\u0d30 \u0d05\u0d35\u0d32\u0d4b\u0d15\u0d28\u0d24\u0d4d\u0d24\u0d46\u0d2f\u0d41\u0d02 \u0d32\u0d2d\u0d4d\u0d2f\u0d2e\u0d3e\u0d2f \u0d35\u0d3f\u0d35\u0d30\u0d19\u0d4d\u0d19\u0d33\u0d46\u0d2f\u0d41\u0d02 \u0d06\u0d36\u0d4d\u0d30\u0d2f\u0d3f\u0d1a\u0d4d\u0d1a\u0d24\u0d41\u0d2e\u0d3e\u0d23\u0d4d. \u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24 \u0d12\u0d30\u0d41 \u0d24\u0d41\u0d1f\u0d7c\u0d28\u0d4d\u0d28 \u0d2a\u0d4d\u0d30\u0d15\u0d4d\u0d30\u0d3f\u0d2f\u0d2f\u0d3e\u0d23\u0d4d; \u0d05\u0d2a\u0d4d\u0d21\u0d47\u0d31\u0d4d\u0d31\u0d41\u0d15\u0d7e \u0d28\u0d1f\u0d2a\u0d4d\u0d2a\u0d3f\u0d32\u0d3e\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d24\u0d3f\u0d28\u0d28\u0d41\u0d38\u0d30\u0d3f\u0d1a\u0d4d\u0d1a\u0d4d \u0d05\u0d28\u0d41\u0d38\u0d30\u0d23 \u0d28\u0d3f\u0d32\u0d15\u0d33\u0d3f\u0d7d \u0d2e\u0d3e\u0d31\u0d4d\u0d31\u0d19\u0d4d\u0d19\u0d7e \u0d35\u0d30\u0d3e\u0d02.\u003C/p\u003E\n\u003Ch2\u003E\u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24 \u0d38\u0d35\u0d3f\u0d36\u0d47\u0d37\u0d24\u0d15\u0d7e\u003C/h2\u003E\n\u003Cp\u003E\u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24\u0d15\u0d4d\u0d15\u0d4d \u0d2a\u0d3f\u0d28\u0d4d\u0d24\u0d41\u0d23 \u0d28\u0d7d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d24\u0d3f\u0d28\u0d3e\u0d2f\u0d3f, \u0d08 \u0d35\u0d46\u0d2c\u0d4d\u0d38\u0d48\u0d31\u0d4d\u0d31\u0d3f\u0d7d AccessYes \u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24 \u0d07\u0d28\u0d4d\u0d31\u0d7c\u0d2b\u0d47\u0d38\u0d4d \u0d09\u0d7e\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24\u0d3f\u0d2f\u0d3f\u0d30\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d41. \u0d09\u0d2a\u0d2f\u0d4b\u0d15\u0d4d\u0d24\u0d3e\u0d15\u0d4d\u0d15\u0d33\u0d41\u0d1f\u0d46 \u0d35\u0d4d\u0d2f\u0d15\u0d4d\u0d24\u0d3f\u0d17\u0d24 \u0d06\u0d35\u0d36\u0d4d\u0d2f\u0d19\u0d4d\u0d19\u0d7e\u0d15\u0d4d\u0d15\u0d28\u0d41\u0d38\u0d30\u0d3f\u0d1a\u0d4d\u0d1a\u0d4d \u0d1a\u0d3f\u0d32 \u0d26\u0d43\u0d36\u0d4d\u0d2f/\u0d09\u0d2a\u0d2f\u0d4b\u0d17 \u0d15\u0d4d\u0d30\u0d2e\u0d40\u0d15\u0d30\u0d23\u0d19\u0d4d\u0d19\u0d7e \u0d07\u0d28\u0d4d\u0d31\u0d7c\u0d2b\u0d47\u0d38\u0d4d \u0d09\u0d2a\u0d2f\u0d4b\u0d17\u0d3f\u0d1a\u0d4d\u0d1a\u0d4d \u0d2e\u0d3e\u0d31\u0d4d\u0d31\u0d3e\u0d7b \u0d15\u0d34\u0d3f\u0d2f\u0d41\u0d02, \u0d09\u0d26\u0d3e\u0d39\u0d30\u0d23\u0d24\u0d4d\u0d24\u0d3f\u0d28\u0d4d:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003E\u0d1f\u0d46\u0d15\u0d4d\u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3f\u0d28\u0d4d\u0d31\u0d46 \u0d35\u0d32\u0d3f\u0d2a\u0d4d\u0d2a\u0d35\u0d41\u0d02 \u0d38\u0d4d\u0d2a\u0d47\u0d38\u0d3f\u0d02\u0d17\u0d41\u0d02 \u0d15\u0d4d\u0d30\u0d2e\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24\u0d7d\u003C/li\u003E\n\u003Cli\u003E\u0d15\u0d4b\u0d7a\u0d1f\u0d4d\u0d30\u0d3e\u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d4d, \u0d15\u0d33\u0d7c \u0d15\u0d4d\u0d30\u0d2e\u0d40\u0d15\u0d30\u0d23\u0d19\u0d4d\u0d19\u0d7e\u003C/li\u003E\n\u003Cli\u003E\u0d39\u0d48\u0d32\u0d48\u0d31\u0d4d\u0d31\u0d3f\u0d02\u0d17\u0d4d \u0d09\u0d2a\u0d15\u0d30\u0d23\u0d19\u0d4d\u0d19\u0d7e\u003C/li\u003E\n\u003Cli\u003E\u0d2e\u0d31\u0d4d\u0d31\u0d4d \u0d38\u0d39\u0d3e\u0d2f\u0d15\u0d2e\u0d3e\u0d2f \u0d26\u0d43\u0d36\u0d4d\u0d2f\u0d2e\u0d3e\u0d15\u0d4d\u0d15\u0d7d \u0d13\u0d2a\u0d4d\u0d37\u0d28\u0d41\u0d15\u0d7e\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003E\u0d08 \u0d09\u0d2a\u0d15\u0d30\u0d23\u0d19\u0d4d\u0d19\u0d7e \u0d09\u0d2a\u0d2f\u0d4b\u0d15\u0d4d\u0d24\u0d43 \u0d2a\u0d30\u0d3f\u0d1a\u0d2f\u0d02 \u0d2e\u0d46\u0d1a\u0d4d\u0d1a\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24\u0d3e\u0d7b \u0d32\u0d15\u0d4d\u0d37\u0d4d\u0d2f\u0d2e\u0d3f\u0d1f\u0d41\u0d28\u0d4d\u0d28\u0d24\u0d3e\u0d23\u0d4d; \u0d0e\u0d28\u0d4d\u0d28\u0d3e\u0d7d, \u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d2e\u0d3e\u0d2f \u0d09\u0d33\u0d4d\u0d33\u0d1f\u0d15\u0d4d\u0d15\u0d24\u0d4d\u0d24\u0d3f\u0d28\u0d4d\u0d31\u0d46\u0d2f\u0d41\u0d02 \u0d36\u0d30\u0d3f\u0d2f\u0d3e\u0d2f \u0d38\u0d48\u0d31\u0d4d\u0d31\u0d3f\u0d28\u0d4d\u0d31\u0d46 \u0d05\u0d1f\u0d3f\u0d38\u0d4d\u0d25\u0d3e\u0d28\u0d02 \u0d18\u0d1f\u0d28\u0d2f\u0d41\u0d1f\u0d46\u0d2f\u0d41\u0d02 \u0d06\u0d35\u0d36\u0d4d\u0d2f\u0d15\u0d24\u0d2f\u0d46 \u0d07\u0d24\u0d4d \u0d2e\u0d3e\u0d31\u0d4d\u0d31\u0d3f\u0d38\u0d4d\u0d25\u0d3e\u0d2a\u0d3f\u0d15\u0d4d\u0d15\u0d3f\u0d32\u0d4d\u0d32.\u003C/p\u003E\n\u003Ch2\u003E\u0d2a\u0d30\u0d3f\u0d2e\u0d3f\u0d24\u0d3f\u0d15\u0d33\u0d41\u0d02 \u0d38\u0d3e\u0d19\u0d4d\u0d15\u0d47\u0d24\u0d3f\u0d15 \u0d2a\u0d30\u0d3f\u0d17\u0d23\u0d28\u0d15\u0d33\u0d41\u0d02\u003C/h2\u003E\n\u003Cp\u003E\u0d24\u0d3e\u0d34\u0d46 \u0d2a\u0d31\u0d2f\u0d41\u0d28\u0d4d\u0d28 \u0d15\u0d3e\u0d30\u0d4d\u0d2f\u0d19\u0d4d\u0d19\u0d7e \u0d36\u0d4d\u0d30\u0d26\u0d4d\u0d27\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d15:\u003C/p\u003E\n\u003Cp\u003E\u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24\u0d3e \u0d38\u0d35\u0d3f\u0d36\u0d47\u0d37\u0d24\u0d15\u0d33\u0d41\u0d1f\u0d46 \u0d32\u0d2d\u0d4d\u0d2f\u0d24\u0d2f\u0d41\u0d02 \u0d2b\u0d32\u0d2a\u0d4d\u0d30\u0d3e\u0d2a\u0d4d\u0d24\u0d3f\u0d2f\u0d41\u0d02 \u0d35\u0d46\u0d2c\u0d4d\u0d38\u0d48\u0d31\u0d4d\u0d31\u0d4d \u0d15\u0d4b\u0d7a\u0d2b\u0d3f\u0d17\u0d31\u0d47\u0d37\u0d28\u0d41\u0d02 \u0d24\u0d41\u0d1f\u0d7c\u0d1a\u0d4d\u0d1a\u0d3e\u0d2f \u0d2a\u0d30\u0d3f\u0d2a\u0d3e\u0d32\u0d28\u0d24\u0d4d\u0d24\u0d3f\u0d28\u0d41\u0d02 \u0d06\u0d36\u0d4d\u0d30\u0d2f\u0d3f\u0d1a\u0d4d\u0d1a\u0d3f\u0d30\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d41.\u003C/p\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{website_url}}\u003C/strong\u003E \u0d2e\u0d41\u0d34\u0d41\u0d35\u0d28\u0d41\u0d02 \u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24 \u0d09\u0d31\u0d2a\u0d4d\u0d2a\u0d3e\u0d15\u0d4d\u0d15\u0d3e\u0d7b \u0d1e\u0d19\u0d4d\u0d19\u0d7e \u0d2a\u0d30\u0d3f\u0d36\u0d4d\u0d30\u0d2e\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d41\u0d35\u0d46\u0d19\u0d4d\u0d15\u0d3f\u0d32\u0d41\u0d02, \u0d1a\u0d3f\u0d32 \u0d09\u0d33\u0d4d\u0d33\u0d1f\u0d15\u0d4d\u0d15\u0d19\u0d4d\u0d19\u0d7e/\u0d38\u0d35\u0d3f\u0d36\u0d47\u0d37\u0d24\u0d15\u0d7e \u0d07\u0d2a\u0d4d\u0d2a\u0d4b\u0d34\u0d41\u0d02 \u0d24\u0d46\u0d30\u0d1e\u0d4d\u0d1e\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24 \u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24\u0d3e \u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d7b\u0d21\u0d47\u0d21\u0d41\u0d15\u0d7e \u0d2a\u0d42\u0d7c\u0d23\u0d4d\u0d23\u0d2e\u0d3e\u0d2f\u0d3f \u0d2a\u0d3e\u0d32\u0d3f\u0d15\u0d4d\u0d15\u0d23\u0d2e\u0d46\u0d28\u0d4d\u0d28\u0d3f\u0d32\u0d4d\u0d32. \u0d1a\u0d3f\u0d32 \u0d09\u0d33\u0d4d\u0d33\u0d1f\u0d15\u0d4d\u0d15\u0d19\u0d4d\u0d19\u0d7e \u0d2e\u0d42\u0d28\u0d4d\u0d28\u0d3e\u0d02 \u0d15\u0d15\u0d4d\u0d37\u0d3f\u0d15\u0d7e \u0d28\u0d7d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d24\u0d3e\u0d2f\u0d3f\u0d30\u0d3f\u0d15\u0d4d\u0d15\u0d3e\u0d02, \u0d05\u0d32\u0d4d\u0d32\u0d46\u0d19\u0d4d\u0d15\u0d3f\u0d7d \u0d1e\u0d19\u0d4d\u0d19\u0d33\u0d41\u0d1f\u0d46 \u0d24\u0d7d\u0d15\u0d4d\u0d37\u0d23 \u0d28\u0d3f\u0d2f\u0d28\u0d4d\u0d24\u0d4d\u0d30\u0d23\u0d24\u0d4d\u0d24\u0d3f\u0d28\u0d4d \u0d05\u0d24\u0d40\u0d24\u0d2e\u0d3e\u0d2f \u0d38\u0d3e\u0d19\u0d4d\u0d15\u0d47\u0d24\u0d3f\u0d15 \u0d2a\u0d30\u0d3f\u0d27\u0d3f\u0d15\u0d7e \u0d05\u0d24\u0d3f\u0d28\u0d46 \u0d2c\u0d3e\u0d27\u0d3f\u0d1a\u0d4d\u0d1a\u0d3f\u0d30\u0d3f\u0d15\u0d4d\u0d15\u0d3e\u0d02.\u003C/p\u003E\n\u003Cp\u003E\u0d15\u0d42\u0d1f\u0d3e\u0d24\u0d46, \u0d1a\u0d3f\u0d32 \u0d2a\u0d48\u0d24\u0d43\u0d15 \u0d09\u0d33\u0d4d\u0d33\u0d1f\u0d15\u0d4d\u0d15\u0d19\u0d4d\u0d19\u0d7e \u0d05\u0d32\u0d4d\u0d32\u0d46\u0d19\u0d4d\u0d15\u0d3f\u0d7d \u0d07\u0d28\u0d4d\u0d31\u0d17\u0d4d\u0d30\u0d47\u0d37\u0d28\u0d41\u0d15\u0d7e \u0d07\u0d2a\u0d4d\u0d2a\u0d4b\u0d34\u0d41\u0d02 \u0d24\u0d46\u0d30\u0d1e\u0d4d\u0d1e\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24 \u0d38\u0d4d\u0d31\u0d4d\u0d31\u0d3e\u0d7b\u0d21\u0d47\u0d21\u0d41\u0d2e\u0d3e\u0d2f\u0d3f \u0d2a\u0d42\u0d7c\u0d23\u0d4d\u0d23\u0d2e\u0d3e\u0d2f\u0d41\u0d02 \u0d2f\u0d4b\u0d1c\u0d3f\u0d15\u0d4d\u0d15\u0d23\u0d2e\u0d46\u0d28\u0d4d\u0d28\u0d3f\u0d32\u0d4d\u0d32. \u0d1e\u0d19\u0d4d\u0d19\u0d33\u0d41\u0d1f\u0d46 \u0d28\u0d3f\u0d2f\u0d28\u0d4d\u0d24\u0d4d\u0d30\u0d23 \u0d2a\u0d30\u0d3f\u0d27\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d33\u0d4d\u0d33\u0d3f\u0d32\u0d46 \u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28 \u0d24\u0d1f\u0d38\u0d4d\u0d38\u0d19\u0d4d\u0d19\u0d7e \u0d15\u0d23\u0d4d\u0d1f\u0d46\u0d24\u0d4d\u0d24\u0d3e\u0d28\u0d41\u0d02 \u0d2a\u0d30\u0d3f\u0d39\u0d30\u0d3f\u0d15\u0d4d\u0d15\u0d3e\u0d28\u0d41\u0d02 \u0d1e\u0d19\u0d4d\u0d19\u0d7e \u0d38\u0d1c\u0d40\u0d35\u0d2e\u0d3e\u0d2f\u0d3f \u0d2a\u0d4d\u0d30\u0d35\u0d7c\u0d24\u0d4d\u0d24\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d41.\u003C/p\u003E\n\u003Ch2\u003E\u0d2b\u0d40\u0d21\u0d4d\u0d2c\u0d3e\u0d15\u0d4d\u0d15\u0d41\u0d02 \u0d2c\u0d28\u0d4d\u0d27\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d32\u0d41\u0d02\u003C/h2\u003E\n\u003Cp\u003E\u0d08 \u0d35\u0d46\u0d2c\u0d4d\u0d38\u0d48\u0d31\u0d4d\u0d31\u0d3f\u0d32\u0d46 \u0d09\u0d33\u0d4d\u0d33\u0d1f\u0d15\u0d4d\u0d15\u0d24\u0d4d\u0d24\u0d3f\u0d32\u0d46\u0d24\u0d4d\u0d24\u0d41\u0d28\u0d4d\u0d28\u0d24\u0d3f\u0d7d \u0d28\u0d3f\u0d19\u0d4d\u0d19\u0d7e\u0d15\u0d4d\u0d15\u0d4d \u0d2c\u0d41\u0d26\u0d4d\u0d27\u0d3f\u0d2e\u0d41\u0d1f\u0d4d\u0d1f\u0d4d \u0d28\u0d47\u0d30\u0d3f\u0d1f\u0d4d\u0d1f\u0d3e\u0d7d, \u0d05\u0d32\u0d4d\u0d32\u0d46\u0d19\u0d4d\u0d15\u0d3f\u0d7d \u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28 \u0d2a\u0d4d\u0d30\u0d36\u0d4d\u0d28\u0d02 \u0d31\u0d3f\u0d2a\u0d4d\u0d2a\u0d4b\u0d7c\u0d1f\u0d4d\u0d1f\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d3e\u0d7b \u0d06\u0d17\u0d4d\u0d30\u0d39\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d41\u0d35\u0d46\u0d19\u0d4d\u0d15\u0d3f\u0d7d, \u0d26\u0d2f\u0d35\u0d3e\u0d2f\u0d3f \u0d1e\u0d19\u0d4d\u0d19\u0d33\u0d41\u0d2e\u0d3e\u0d2f\u0d3f \u0d2c\u0d28\u0d4d\u0d27\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d15:\u003C/p\u003E\n\u003Cp\u003E\u0d07&#8209;\u0d2e\u0d46\u0d2f\u0d3f\u0d7d: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003E\u0d2c\u0d28\u0d4d\u0d27\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d2e\u0d4d\u0d2a\u0d4b\u0d7e, \u0d28\u0d3f\u0d7c\u0d26\u0d4d\u0d26\u0d3f\u0d37\u0d4d\u0d1f \u0d2a\u0d47\u0d1c\u0d3f\u0d28\u0d4d\u0d31\u0d46 URL \u0d09\u0d02 \u0d2a\u0d4d\u0d30\u0d36\u0d4d\u0d28\u0d24\u0d4d\u0d24\u0d3f\u0d28\u0d4d\u0d31\u0d46 \u0d35\u0d3f\u0d35\u0d30\u0d23\u0d35\u0d41\u0d02 \u0d09\u0d7e\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24\u0d41\u0d15, \u0d05\u0d24\u0d41\u0d35\u0d34\u0d3f \u0d1e\u0d19\u0d4d\u0d19\u0d7e\u0d15\u0d4d\u0d15\u0d4d \u0d2a\u0d30\u0d3f\u0d36\u0d4b\u0d27\u0d3f\u0d15\u0d4d\u0d15\u0d3e\u0d28\u0d41\u0d02 \u0d2f\u0d4b\u0d1c\u0d4d\u0d2f\u0d2e\u0d3e\u0d2f\u0d3f \u0d2a\u0d4d\u0d30\u0d24\u0d3f\u0d15\u0d30\u0d3f\u0d15\u0d4d\u0d15\u0d3e\u0d28\u0d41\u0d02 \u0d15\u0d34\u0d3f\u0d2f\u0d41\u0d02.\u003C/p\u003E\n\u003Ch2\u003E\u0d24\u0d41\u0d1f\u0d7c\u0d1a\u0d4d\u0d1a\u0d2f\u0d3e\u0d2f \u0d2e\u0d46\u0d1a\u0d4d\u0d1a\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24\u0d7d\u003C/h2\u003E\n\u003Cp\u003E\u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24 \u0d12\u0d30\u0d41 \u0d24\u0d41\u0d1f\u0d7c\u0d1a\u0d4d\u0d1a\u0d2f\u0d3e\u0d2f \u0d36\u0d4d\u0d30\u0d2e\u0d2e\u0d3e\u0d23\u0d4d. \u0d1e\u0d19\u0d4d\u0d19\u0d7e \u0d28\u0d2e\u0d4d\u0d2e\u0d41\u0d1f\u0d46 \u0d35\u0d46\u0d2c\u0d4d\u0d38\u0d48\u0d31\u0d4d\u0d31\u0d4d \u0d2a\u0d24\u0d3f\u0d35\u0d3e\u0d2f\u0d3f \u0d05\u0d35\u0d32\u0d4b\u0d15\u0d28\u0d02 \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d15\u0d2f\u0d41\u0d02 \u0d2a\u0d4d\u0d30\u0d35\u0d47\u0d36\u0d28\u0d2f\u0d4b\u0d17\u0d4d\u0d2f\u0d24\u0d2f\u0d41\u0d02 \u0d09\u0d2a\u0d2f\u0d4b\u0d17\u0d2a\u0d4d\u0d30\u0d3e\u0d2f\u0d4b\u0d17\u0d3f\u0d15\u0d24\u0d2f\u0d41\u0d02 \u0d2e\u0d46\u0d1a\u0d4d\u0d1a\u0d2a\u0d4d\u0d2a\u0d46\u0d1f\u0d41\u0d24\u0d4d\u0d24\u0d3e\u0d28\u0d41\u0d33\u0d4d\u0d33 \u0d05\u0d35\u0d38\u0d30\u0d19\u0d4d\u0d19\u0d7e \u0d35\u0d3f\u0d32\u0d2f\u0d3f\u0d30\u0d41\u0d24\u0d4d\u0d24\u0d41\u0d15\u0d2f\u0d41\u0d02 \u0d1a\u0d46\u0d2f\u0d4d\u0d2f\u0d41\u0d28\u0d4d\u0d28\u0d41.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003E\u0d05\u0d35\u0d38\u0d3e\u0d28\u0d2e\u0d3e\u0d2f\u0d3f \u0d2a\u0d41\u0d24\u0d41\u0d15\u0d4d\u0d15\u0d3f\u0d2f\u0d24\u0d4d: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"\u0d2a\u0d42\u0d7c\u0d23\u0d4d\u0d23\u0d2e\u0d3e\u0d2f\u0d3f \u0d05\u0d28\u0d41\u0d38\u0d30\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d24\u0d4d","partially-conformant":"\u0d2d\u0d3e\u0d17\u0d3f\u0d15\u0d2e\u0d3e\u0d2f\u0d3f \u0d05\u0d28\u0d41\u0d38\u0d30\u0d3f\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d24\u0d4d","non-conformant":"\u0d05\u0d28\u0d41\u0d38\u0d30\u0d3f\u0d15\u0d4d\u0d15\u0d3e\u0d24\u0d4d\u0d24\u0d24\u0d4d","not-assessed":"\u0d06\u0d15\u0d4d\u0d38\u0d38\u0d4d \u0d1a\u0d46\u0d2f\u0d4d\u0d24\u0d3f\u0d1f\u0d4d\u0d1f\u0d3f\u0d32\u0d4d\u0d32"}},"nl":{"template":"\u003Ch2\u003EToegankelijkheidsbelofte\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E zet zich in om de toegankelijkheid en bruikbaarheid van \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E voor alle gebruikers te verbeteren, inclusief mensen met een beperking. We streven naar een inclusieve digitale ervaring en werken continu aan het verbeteren van de toegankelijkheid van onze website.\u003C/p\u003E\n\u003Ch2\u003EDoelstandaard voor toegankelijkheid\u003C/h2\u003E\n\u003Cp\u003EWij streven ernaar onze website af te stemmen op de toegankelijkheidsstandaard \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EDeze doelstandaard geeft richting aan onze toegankelijkheidsinspanningen en doorlopende verbeteringen.\u003C/p\u003E\n\u003Ch2\u003EHuidige conformiteitsstatus\u003C/h2\u003E\n\u003Cp\u003EOp basis van onze interne beoordeling is deze website \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E ten opzichte van \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EDeze status weerspiegelt onze beoordeling op het moment van publicatie en is gebaseerd op onze interne review en beschikbare informatie. Toegankelijkheid is een continu proces; conformiteitsniveaus kunnen evolueren naarmate updates worden doorgevoerd.\u003C/p\u003E\n\u003Ch2\u003EToegankelijkheidsfuncties\u003C/h2\u003E\n\u003Cp\u003EOm toegankelijkheid te ondersteunen, bevat deze website de AccessYes-toegankelijkheidsinterface. Met deze interface kunnen gebruikers bepaalde visuele en gebruiksinstellingen aanpassen aan individuele behoeften, zoals:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003EAanpassingen van tekstgrootte en spati\u00ebring\u003C/li\u003E\n\u003Cli\u003EContrast- en kleurinstellingen\u003C/li\u003E\n\u003Cli\u003EMarkeringstools\u003C/li\u003E\n\u003Cli\u003EOverige opties voor ondersteunende weergave\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003EDeze tools zijn bedoeld om de gebruikerservaring te verbeteren, maar vervangen niet de noodzaak van toegankelijke content en een juiste onderliggende sitestructuur.\u003C/p\u003E\n\u003Ch2\u003EBeperkingen en technische overwegingen\u003C/h2\u003E\n\u003Cp\u003EHoud rekening met het volgende:\u003C/p\u003E\n\u003Cp\u003EDe beschikbaarheid en effectiviteit van toegankelijkheidsfuncties zijn afhankelijk van de configuratie van de website en het doorlopende onderhoud.\u003C/p\u003E\n\u003Cp\u003EHoewel wij ernaar streven toegankelijkheid te waarborgen binnen \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, kan het zijn dat sommige content of functies nog niet volledig voldoen aan de geselecteerde toegankelijkheidsstandaarden. Sommige content kan door derden worden aangeleverd of worden be\u00efnvloed door technische beperkingen buiten onze directe controle.\u003C/p\u003E\n\u003Cp\u003EDaarnaast kan er verouderde content of integraties zijn die nog niet volledig in lijn zijn met de geselecteerde standaard. We werken actief aan het identificeren en wegnemen van toegankelijkheidsbelemmeringen die binnen onze invloedssfeer liggen.\u003C/p\u003E\n\u003Ch2\u003EFeedback en contact\u003C/h2\u003E\n\u003Cp\u003EMocht u problemen ondervinden bij het openen van content op deze website of een toegankelijkheidsprobleem willen melden, neem dan contact met ons op:\u003C/p\u003E\n\u003Cp\u003EE&#8209;mail: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003EVermeld bij uw bericht de specifieke pagina-URL en een beschrijving van het probleem, zodat wij dit kunnen onderzoeken en gepast reageren.\u003C/p\u003E\n\u003Ch2\u003EContinue verbetering\u003C/h2\u003E\n\u003Cp\u003EToegankelijkheid is een doorlopend streven. Wij beoordelen onze website regelmatig en evalueren kansen om toegankelijkheid en bruikbaarheid te verbeteren.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003ELaatst bijgewerkt: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"volledig conform","partially-conformant":"gedeeltelijk conform","non-conformant":"niet conform","not-assessed":"niet benaderd"}},"pl":{"template":"\u003Ch2\u003EZobowi\u0105zanie w zakresie dost\u0119pno\u015bci\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E zobowi\u0105zuje si\u0119 do poprawy dost\u0119pno\u015bci i u\u017cyteczno\u015bci serwisu \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E dla wszystkich u\u017cytkownik\u00f3w, w tym os\u00f3b z niepe\u0142nosprawno\u015bciami. D\u0105\u017cymy do zapewnienia inkluzywnego do\u015bwiadczenia cyfrowego i nieustannie pracujemy nad ulepszaniem dost\u0119pno\u015bci naszej witryny.\u003C/p\u003E\n\u003Ch2\u003EDocelowy standard dost\u0119pno\u015bci\u003C/h2\u003E\n\u003Cp\u003ED\u0105\u017cymy do dostosowania naszej witryny do standardu dost\u0119pno\u015bci \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003ETen docelowy standard wyznacza kierunek naszych dzia\u0142a\u0144 i ci\u0105g\u0142ych usprawnie\u0144 w obszarze dost\u0119pno\u015bci.\u003C/p\u003E\n\u003Ch2\u003EAktualny status zgodno\u015bci\u003C/h2\u003E\n\u003Cp\u003ENa podstawie naszej wewn\u0119trznej weryfikacji ta witryna jest \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E w odniesieniu do \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EStatus ten odzwierciedla nasz\u0105 ocen\u0119 w momencie publikacji i opiera si\u0119 na przegl\u0105dzie wewn\u0119trznym oraz dost\u0119pnych informacjach. Dost\u0119pno\u015b\u0107 to proces ci\u0105g\u0142y, a poziomy zgodno\u015bci mog\u0105 si\u0119 zmienia\u0107 wraz z wprowadzaniem aktualizacji.\u003C/p\u003E\n\u003Ch2\u003EFunkcje dost\u0119pno\u015bci\u003C/h2\u003E\n\u003Cp\u003EAby wspiera\u0107 dost\u0119pno\u015b\u0107, ta witryna zawiera interfejs dost\u0119pno\u015bci AccessYes. Interfejs ten umo\u017cliwia u\u017cytkownikom dostosowanie wybranych ustawie\u0144 wizualnych i u\u017cyteczno\u015bci do indywidualnych potrzeb, takich jak:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003ERegulacja rozmiaru tekstu i odst\u0119p\u00f3w\u003C/li\u003E\n\u003Cli\u003EUstawienia kontrastu i kolor\u00f3w\u003C/li\u003E\n\u003Cli\u003ENarz\u0119dzia do wyr\u00f3\u017cniania\u003C/li\u003E\n\u003Cli\u003EInne opcje wspomagaj\u0105cego wy\u015bwietlania\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003ENarz\u0119dzia te maj\u0105 na celu popraw\u0119 wygody korzystania z serwisu, ale nie zast\u0119puj\u0105 potrzeby zapewnienia dost\u0119pnych tre\u015bci i w\u0142a\u015bciwej, zgodnej z zasadami struktury witryny.\u003C/p\u003E\n\u003Ch2\u003EOgraniczenia i kwestie techniczne\u003C/h2\u003E\n\u003Cp\u003EProsimy o uwzgl\u0119dnienie poni\u017cszych informacji:\u003C/p\u003E\n\u003Cp\u003EDost\u0119pno\u015b\u0107 i skuteczno\u015b\u0107 funkcji zale\u017c\u0105 od konfiguracji witryny oraz bie\u017c\u0105cej konserwacji.\u003C/p\u003E\n\u003Cp\u003ECho\u0107 dok\u0142adamy stara\u0144, aby zapewni\u0107 dost\u0119pno\u015b\u0107 w ramach \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, cz\u0119\u015b\u0107 tre\u015bci lub funkcji mo\u017ce jeszcze nie w pe\u0142ni spe\u0142nia\u0107 wybrane standardy dost\u0119pno\u015bci. Niekt\u00f3re tre\u015bci mog\u0105 pochodzi\u0107 od podmiot\u00f3w trzecich lub podlega\u0107 ograniczeniom technicznym poza nasz\u0105 bezpo\u015bredni\u0105 kontrol\u0105.\u003C/p\u003E\n\u003Cp\u003EPonadto mog\u0105 istnie\u0107 tre\u015bci lub integracje o charakterze \u201elegacy\", kt\u00f3re jeszcze nie s\u0105 w pe\u0142ni zgodne z wybranym standardem dost\u0119pno\u015bci. Aktywnie pracujemy nad identyfikowaniem i usuwaniem barier dost\u0119pno\u015bci w zakresie naszych mo\u017cliwo\u015bci.\u003C/p\u003E\n\u003Ch2\u003EInformacje zwrotne i kontakt\u003C/h2\u003E\n\u003Cp\u003EJe\u015bli napotkaj\u0105 Pa\u0144stwo trudno\u015bci z dost\u0119pem do tre\u015bci na tej witrynie lub chc\u0105 zg\u0142osi\u0107 problem z dost\u0119pno\u015bci\u0105, prosimy o kontakt:\u003C/p\u003E\n\u003Cp\u003EE&#8209;mail: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003EW wiadomo\u015bci prosimy poda\u0107 adres URL konkretnej strony oraz opis problemu, aby\u015bmy mogli to zbada\u0107 i odpowiednio zareagowa\u0107.\u003C/p\u003E\n\u003Ch2\u003ECi\u0105g\u0142e doskonalenie\u003C/h2\u003E\n\u003Cp\u003EDost\u0119pno\u015b\u0107 to ci\u0105g\u0142y proces. Regularnie przegl\u0105damy nasz\u0105 witryn\u0119 i oceniamy mo\u017cliwo\u015bci dalszej poprawy dost\u0119pno\u015bci i u\u017cyteczno\u015bci.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003EOstatnia aktualizacja: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"w pe\u0142ni zgodny","partially-conformant":"cz\u0119\u015bciowo zgodny","non-conformant":"niezgodny","not-assessed":"nie uzyskany dost\u0119p"}},"pt":{"template":"\u003Ch2\u003ECompromisso com a Acessibilidade\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E compromete-se a aprimorar a acessibilidade e a usabilidade de \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E para todos os usu\u00e1rios, incluindo pessoas com defici\u00eancia. Buscamos oferecer uma experi\u00eancia digital inclusiva e trabalhamos continuamente para aprimorar a acessibilidade em todo o nosso site.\u003C/p\u003E\n\u003Ch2\u003EPadr\u00e3o de Acessibilidade Alvo\u003C/h2\u003E\n\u003Cp\u003EBuscamos alinhar nosso site ao padr\u00e3o de acessibilidade \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EEsse padr\u00e3o de refer\u00eancia orienta nossos esfor\u00e7os e as melhorias cont\u00ednuas em acessibilidade.\u003C/p\u003E\n\u003Ch2\u003EStatus Atual de Conformidade\u003C/h2\u003E\n\u003Cp\u003ECom base em nossa avalia\u00e7\u00e3o interna, este site est\u00e1 \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E em rela\u00e7\u00e3o ao \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EEsse status reflete nossa avalia\u00e7\u00e3o no momento da publica\u00e7\u00e3o e baseia-se em nossa revis\u00e3o interna e nas informa\u00e7\u00f5es dispon\u00edveis. A acessibilidade \u00e9 um processo cont\u00ednuo, e os n\u00edveis de conformidade podem evoluir \u00e0 medida que as atualiza\u00e7\u00f5es s\u00e3o implementadas.\u003C/p\u003E\n\u003Ch2\u003ERecursos de Acessibilidade\u003C/h2\u003E\n\u003Cp\u003EPara apoiar a acessibilidade, este site inclui a interface de acessibilidade AccessYes. Essa interface permite aos usu\u00e1rios ajustar determinadas configura\u00e7\u00f5es visuais e de usabilidade conforme suas necessidades, tais como:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003EAjustes de tamanho e espa\u00e7amento do texto\u003C/li\u003E\n\u003Cli\u003EConfigura\u00e7\u00f5es de contraste e cores\u003C/li\u003E\n\u003Cli\u003EFerramentas de realce\u003C/li\u003E\n\u003Cli\u003EOutras op\u00e7\u00f5es de exibi\u00e7\u00e3o assistida\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003EEssas ferramentas visam melhorar a experi\u00eancia do usu\u00e1rio, mas n\u00e3o substituem a necessidade de conte\u00fado acess\u00edvel e de uma estrutura t\u00e9cnica adequada do site.\u003C/p\u003E\n\u003Ch2\u003ELimita\u00e7\u00f5es e Considera\u00e7\u00f5es T\u00e9cnicas\u003C/h2\u003E\n\u003Cp\u003EObserve o seguinte:\u003C/p\u003E\n\u003Cp\u003EA disponibilidade e a efic\u00e1cia dos recursos de acessibilidade dependem da configura\u00e7\u00e3o do site e da manuten\u00e7\u00e3o cont\u00ednua.\u003C/p\u003E\n\u003Cp\u003EEmbora nos esforcemos para garantir a acessibilidade em \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, alguns conte\u00fados ou recursos podem ainda n\u00e3o atender plenamente aos padr\u00f5es de acessibilidade selecionados. Parte do conte\u00fado pode ser fornecida por terceiros ou ser afetada por limita\u00e7\u00f5es t\u00e9cnicas fora de nosso controle imediato.\u003C/p\u003E\n\u003Cp\u003EAl\u00e9m disso, pode haver conte\u00fados ou integra\u00e7\u00f5es legados que ainda n\u00e3o estejam totalmente alinhados ao padr\u00e3o de acessibilidade selecionado. Trabalhamos ativamente para identificar e tratar as barreiras de acessibilidade sob nosso controle.\u003C/p\u003E\n\u003Ch2\u003EFeedback e Contato\u003C/h2\u003E\n\u003Cp\u003ESe voc\u00ea tiver dificuldade para acessar conte\u00fado neste site ou quiser relatar um problema de acessibilidade, entre em contato conosco:\u003C/p\u003E\n\u003Cp\u003EE&#8209;mail: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003EAo entrar em contato, inclua a URL espec\u00edfica da p\u00e1gina e uma descri\u00e7\u00e3o do problema para que possamos investigar e responder adequadamente.\u003C/p\u003E\n\u003Ch2\u003EMelhoria Cont\u00ednua\u003C/h2\u003E\n\u003Cp\u003EA acessibilidade \u00e9 um esfor\u00e7o cont\u00ednuo. Revisamos regularmente nosso site e avaliamos oportunidades para melhorar a acessibilidade e a usabilidade.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003E\u00daltima atualiza\u00e7\u00e3o: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"totalmente conforme","partially-conformant":"parcialmente conforme","non-conformant":"n\u00e3o conforme","not-assessed":"n\u00e3o acessado"}},"ro":{"template":"\u003Ch2\u003EAngajament privind accesibilitatea\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E se angajeaz\u0103 s\u0103 \u00eembun\u0103t\u0103\u021beasc\u0103 accesibilitatea \u0219i u\u0219urin\u021ba \u00een utilizare a \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E pentru to\u021bi utilizatorii, inclusiv pentru persoanele cu dizabilit\u0103\u021bi. Ne propunem s\u0103 oferim o experien\u021b\u0103 digital\u0103 incluziv\u0103 \u0219i lucr\u0103m \u00een mod constant pentru a \u00eembun\u0103t\u0103\u021bi accesibilitatea pe \u00eentregul nostru site.\u003C/p\u003E\n\u003Ch2\u003EStandardul \u021bint\u0103 de accesibilitate\u003C/h2\u003E\n\u003Cp\u003ENe propunem s\u0103 aliniem site-ul nostru la standardul de accesibilitate \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EAcest standard \u021bint\u0103 ne ghideaz\u0103 eforturile \u0219i \u00eembun\u0103t\u0103\u021birile continue privind accesibilitatea.\u003C/p\u003E\n\u003Ch2\u003EStare curent\u0103 de conformitate\u003C/h2\u003E\n\u003Cp\u003EPe baza evalu\u0103rii noastre interne, acest site este \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E \u00een raport cu \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003EAceast\u0103 stare reflect\u0103 evaluarea noastr\u0103 la momentul public\u0103rii \u0219i se bazeaz\u0103 pe analiza intern\u0103 \u0219i pe informa\u021biile disponibile. Accesibilitatea este un proces continuu, iar nivelurile de conformitate pot evolua pe m\u0103sur\u0103 ce sunt implementate actualiz\u0103ri.\u003C/p\u003E\n\u003Ch2\u003EFunc\u021bionalit\u0103\u021bi de accesibilitate\u003C/h2\u003E\n\u003Cp\u003EPentru a sprijini accesibilitatea, acest site include interfa\u021ba de accesibilitate AccessYes. Aceast\u0103 interfa\u021b\u0103 permite ajustarea anumitor set\u0103ri vizuale \u0219i de utilizare, \u00een func\u021bie de nevoile individuale, precum:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003EAjust\u0103ri ale dimensiunii \u0219i spa\u021bierii textului\u003C/li\u003E\n\u003Cli\u003ESet\u0103ri de contrast \u0219i culoare\u003C/li\u003E\n\u003Cli\u003EInstrumente de eviden\u021biere\u003C/li\u003E\n\u003Cli\u003EAlte op\u021biuni de afi\u0219are asistat\u0103\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003EAceste instrumente sunt destinate \u00eembun\u0103t\u0103\u021birii experien\u021bei utilizatorilor, \u00eens\u0103 nu \u00eenlocuiesc necesitatea con\u021binutului accesibil \u0219i a unei structuri tehnice adecvate a site-ului.\u003C/p\u003E\n\u003Ch2\u003ELimit\u0103ri \u0219i considerente tehnice\u003C/h2\u003E\n\u003Cp\u003EV\u0103 rug\u0103m s\u0103 ave\u021bi \u00een vedere urm\u0103toarele:\u003C/p\u003E\n\u003Cp\u003EDisponibilitatea \u0219i eficacitatea func\u021bionalit\u0103\u021bilor de accesibilitate depind de configura\u021bia site-ului \u0219i de mentenan\u021ba continu\u0103.\u003C/p\u003E\n\u003Cp\u003EDe\u0219i depunem eforturi pentru a asigura accesibilitatea \u00een cadrul \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, este posibil ca anumite con\u021binuturi sau func\u021bionalit\u0103\u021bi s\u0103 nu \u00eendeplineasc\u0103 \u00eenc\u0103 pe deplin standardele de accesibilitate selectate. O parte din con\u021binut poate fi furnizat de ter\u021bi sau poate fi afectat de constr\u00e2ngeri tehnice aflate \u00een afara controlului nostru imediat.\u003C/p\u003E\n\u003Cp\u003E\u00cen plus, pot exista con\u021binuturi sau integr\u0103ri vechi care nu sunt \u00eenc\u0103 pe deplin aliniate la standardul de accesibilitate selectat. Lucr\u0103m activ pentru a identifica \u0219i remedia barierele de accesibilitate aflate sub controlul nostru.\u003C/p\u003E\n\u003Ch2\u003EFeedback \u0219i contact\u003C/h2\u003E\n\u003Cp\u003EDac\u0103 \u00eent\u00e2mpina\u021bi dificult\u0103\u021bi \u00een accesarea con\u021binutului de pe acest site sau dori\u021bi s\u0103 raporta\u021bi o problem\u0103 de accesibilitate, v\u0103 rug\u0103m s\u0103 ne contacta\u021bi:\u003C/p\u003E\n\u003Cp\u003EE&#8209;mail: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003EC\u00e2nd ne contacta\u021bi, include\u021bi adresa URL a paginii specifice \u0219i o descriere a problemei, pentru a putea investiga \u0219i r\u0103spunde \u00een mod adecvat.\u003C/p\u003E\n\u003Ch2\u003E\u00cembun\u0103t\u0103\u021bire continu\u0103\u003C/h2\u003E\n\u003Cp\u003EAccesibilitatea este un demers continuu. Revizuim periodic site-ul \u0219i evalu\u0103m oportunit\u0103\u021bi de a \u00eembun\u0103t\u0103\u021bi accesibilitatea \u0219i u\u0219urin\u021ba \u00een utilizare.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003EUltima actualizare: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"pe deplin conform","partially-conformant":"par\u021bial conform","non-conformant":"neconform","not-assessed":"neaccesat"}},"ru":{"template":"\u003Ch2\u003E\u041e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u0430 \u043f\u043e \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u044e \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E \u0441\u0442\u0440\u0435\u043c\u0438\u0442\u0441\u044f \u043f\u043e\u0432\u044b\u0441\u0438\u0442\u044c \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u044c \u0438 \u0443\u0434\u043e\u0431\u0441\u0442\u0432\u043e \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u044f \u0441\u0430\u0439\u0442\u0430 \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E \u0434\u043b\u044f \u0432\u0441\u0435\u0445 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u0435\u0439, \u0432\u043a\u043b\u044e\u0447\u0430\u044f \u043b\u044e\u0434\u0435\u0439 \u0441 \u0438\u043d\u0432\u0430\u043b\u0438\u0434\u043d\u043e\u0441\u0442\u044c\u044e. \u041d\u0430\u0448\u0430 \u0446\u0435\u043b\u044c \u2014 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0438\u0442\u044c \u0438\u043d\u043a\u043b\u044e\u0437\u0438\u0432\u043d\u044b\u0439 \u0446\u0438\u0444\u0440\u043e\u0432\u043e\u0439 \u043e\u043f\u044b\u0442, \u0438 \u043c\u044b \u043f\u043e\u0441\u0442\u043e\u044f\u043d\u043d\u043e \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u043c \u043d\u0430\u0434 \u0443\u043b\u0443\u0447\u0448\u0435\u043d\u0438\u0435\u043c \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438 \u043d\u0430 \u043d\u0430\u0448\u0435\u043c \u0441\u0430\u0439\u0442\u0435.\u003C/p\u003E\n\u003Ch2\u003E\u0426\u0435\u043b\u0435\u0432\u043e\u0439 \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438\u003C/h2\u003E\n\u003Cp\u003E\u041c\u044b \u0441\u0442\u0440\u0435\u043c\u0438\u043c\u0441\u044f \u043f\u0440\u0438\u0432\u0435\u0441\u0442\u0438 \u043d\u0430\u0448 \u0441\u0430\u0439\u0442 \u0432 \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435 \u0441\u043e \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u043e\u043c \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438 \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003E\u042d\u0442\u043e\u0442 \u0446\u0435\u043b\u0435\u0432\u043e\u0439 \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442 \u043d\u0430\u0448\u0438 \u0443\u0441\u0438\u043b\u0438\u044f \u0438 \u043d\u0435\u043f\u0440\u0435\u0440\u044b\u0432\u043d\u044b\u0435 \u0443\u043b\u0443\u0447\u0448\u0435\u043d\u0438\u044f \u0432 \u043e\u0431\u043b\u0430\u0441\u0442\u0438 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438.\u003C/p\u003E\n\u003Ch2\u003E\u0422\u0435\u043a\u0443\u0449\u0438\u0439 \u0441\u0442\u0430\u0442\u0443\u0441 \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u044f\u003C/h2\u003E\n\u003Cp\u003E\u0421\u043e\u0433\u043b\u0430\u0441\u043d\u043e \u043d\u0430\u0448\u0435\u0439 \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0435\u0439 \u043e\u0446\u0435\u043d\u043a\u0435, \u0434\u0430\u043d\u043d\u044b\u0439 \u0441\u0430\u0439\u0442 \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E \u0432 \u043e\u0442\u043d\u043e\u0448\u0435\u043d\u0438\u0438 \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E.\u003C/p\u003E\n\u003Cp\u003E\u042d\u0442\u043e\u0442 \u0441\u0442\u0430\u0442\u0443\u0441 \u043e\u0442\u0440\u0430\u0436\u0430\u0435\u0442 \u043d\u0430\u0448\u0443 \u043e\u0446\u0435\u043d\u043a\u0443 \u043d\u0430 \u043c\u043e\u043c\u0435\u043d\u0442 \u043f\u0443\u0431\u043b\u0438\u043a\u0430\u0446\u0438\u0438 \u0438 \u043e\u0441\u043d\u043e\u0432\u0430\u043d \u043d\u0430 \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0435\u043c \u043e\u0431\u0437\u043e\u0440\u0435 \u0438 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0439 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u0438. \u0414\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u044c \u2014 \u044d\u0442\u043e \u043d\u0435\u043f\u0440\u0435\u0440\u044b\u0432\u043d\u044b\u0439 \u043f\u0440\u043e\u0446\u0435\u0441\u0441; \u0443\u0440\u043e\u0432\u043d\u0438 \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u044f \u043c\u043e\u0433\u0443\u0442 \u0438\u0437\u043c\u0435\u043d\u044f\u0442\u044c\u0441\u044f \u043f\u043e \u043c\u0435\u0440\u0435 \u0432\u043d\u0435\u0434\u0440\u0435\u043d\u0438\u044f \u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u0439.\u003C/p\u003E\n\u003Ch2\u003E\u0424\u0443\u043d\u043a\u0446\u0438\u0438 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438\u003C/h2\u003E\n\u003Cp\u003E\u0414\u043b\u044f \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u043a\u0438 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438 \u043d\u0430 \u044d\u0442\u043e\u043c \u0441\u0430\u0439\u0442\u0435 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f \u0438\u043d\u0442\u0435\u0440\u0444\u0435\u0439\u0441 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438 AccessYes. \u042d\u0442\u043e\u0442 \u0438\u043d\u0442\u0435\u0440\u0444\u0435\u0439\u0441 \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0435\u0442 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044f\u043c \u043d\u0430\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0442\u044c \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u044b\u0435 \u0432\u0438\u0437\u0443\u0430\u043b\u044c\u043d\u044b\u0435 \u0438 \u044d\u043a\u0441\u043f\u043b\u0443\u0430\u0442\u0430\u0446\u0438\u043e\u043d\u043d\u044b\u0435 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b \u0432 \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0438 \u0441 \u0438\u043d\u0434\u0438\u0432\u0438\u0434\u0443\u0430\u043b\u044c\u043d\u044b\u043c\u0438 \u043f\u043e\u0442\u0440\u0435\u0431\u043d\u043e\u0441\u0442\u044f\u043c\u0438, \u0442\u0430\u043a\u0438\u0435 \u043a\u0430\u043a:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003E\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0430 \u0440\u0430\u0437\u043c\u0435\u0440\u0430 \u0442\u0435\u043a\u0441\u0442\u0430 \u0438 \u0438\u043d\u0442\u0435\u0440\u0432\u0430\u043b\u043e\u0432\u003C/li\u003E\n\u003Cli\u003E\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b \u043a\u043e\u043d\u0442\u0440\u0430\u0441\u0442\u043d\u043e\u0441\u0442\u0438 \u0438 \u0446\u0432\u0435\u0442\u043e\u0432\u003C/li\u003E\n\u003Cli\u003E\u0418\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u044b \u0432\u044b\u0434\u0435\u043b\u0435\u043d\u0438\u044f\u003C/li\u003E\n\u003Cli\u003E\u0414\u0440\u0443\u0433\u0438\u0435 \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u044b \u0432\u0441\u043f\u043e\u043c\u043e\u0433\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u0430\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003E\u042d\u0442\u0438 \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u044b \u043f\u0440\u0438\u0437\u0432\u0430\u043d\u044b \u0443\u043b\u0443\u0447\u0448\u0438\u0442\u044c \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u0441\u043a\u0438\u0439 \u043e\u043f\u044b\u0442, \u043d\u043e \u043d\u0435 \u0437\u0430\u043c\u0435\u043d\u044f\u044e\u0442 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e\u0441\u0442\u0438 \u0432 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u043c \u043a\u043e\u043d\u0442\u0435\u043d\u0442\u0435 \u0438 \u043a\u043e\u0440\u0440\u0435\u043a\u0442\u043d\u043e\u0439 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0435 \u0441\u0430\u0439\u0442\u0430.\u003C/p\u003E\n\u003Ch2\u003E\u041e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u044f \u0438 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0441\u043e\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u044f\u003C/h2\u003E\n\u003Cp\u003E\u041e\u0431\u0440\u0430\u0442\u0438\u0442\u0435 \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u043d\u0430 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0435:\u003C/p\u003E\n\u003Cp\u003E\u0414\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u044c \u0438 \u044d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u044c \u0444\u0443\u043d\u043a\u0446\u0438\u0439 \u0437\u0430\u0432\u0438\u0441\u044f\u0442 \u043e\u0442 \u043a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u0438 \u0441\u0430\u0439\u0442\u0430 \u0438 \u043f\u043e\u0441\u0442\u043e\u044f\u043d\u043d\u043e\u0433\u043e \u043e\u0431\u0441\u043b\u0443\u0436\u0438\u0432\u0430\u043d\u0438\u044f.\u003C/p\u003E\n\u003Cp\u003E\u041d\u0435\u0441\u043c\u043e\u0442\u0440\u044f \u043d\u0430 \u043d\u0430\u0448\u0438 \u0443\u0441\u0438\u043b\u0438\u044f \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0438\u0442\u044c \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u044c \u043d\u0430 \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E, \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u044b\u0435 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044b \u0438\u043b\u0438 \u0444\u0443\u043d\u043a\u0446\u0438\u0438 \u043c\u043e\u0433\u0443\u0442 \u043f\u043e\u043a\u0430 \u043d\u0435 \u0432 \u043f\u043e\u043b\u043d\u043e\u0439 \u043c\u0435\u0440\u0435 \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u043e\u0432\u0430\u0442\u044c \u0432\u044b\u0431\u0440\u0430\u043d\u043d\u044b\u043c \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u0430\u043c \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438. \u0427\u0430\u0441\u0442\u044c \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u043e\u0432 \u043c\u043e\u0436\u0435\u0442 \u043f\u0440\u0435\u0434\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0442\u044c\u0441\u044f \u0442\u0440\u0435\u0442\u044c\u0438\u043c\u0438 \u0441\u0442\u043e\u0440\u043e\u043d\u0430\u043c\u0438 \u0438\u043b\u0438 \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0438\u0432\u0430\u0442\u044c\u0441\u044f \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u043c\u0438 \u0444\u0430\u043a\u0442\u043e\u0440\u0430\u043c\u0438 \u0432\u043d\u0435 \u043d\u0430\u0448\u0435\u0439 \u043d\u0435\u043f\u043e\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0439 \u0437\u043e\u043d\u044b \u043a\u043e\u043d\u0442\u0440\u043e\u043b\u044f.\u003C/p\u003E\n\u003Cp\u003E\u041a\u0440\u043e\u043c\u0435 \u0442\u043e\u0433\u043e, \u043c\u043e\u0436\u0435\u0442 \u0438\u043c\u0435\u0442\u044c\u0441\u044f \u0443\u043d\u0430\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u043d\u044b\u0439 \u043a\u043e\u043d\u0442\u0435\u043d\u0442 \u0438\u043b\u0438 \u0438\u043d\u0442\u0435\u0433\u0440\u0430\u0446\u0438\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u043e\u043a\u0430 \u043d\u0435 \u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u0441\u043e\u0433\u043b\u0430\u0441\u043e\u0432\u0430\u043d\u044b \u0441 \u0432\u044b\u0431\u0440\u0430\u043d\u043d\u044b\u043c \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u043e\u043c. \u041c\u044b \u0430\u043a\u0442\u0438\u0432\u043d\u043e \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u043c \u043d\u0430\u0434 \u0432\u044b\u044f\u0432\u043b\u0435\u043d\u0438\u0435\u043c \u0438 \u0443\u0441\u0442\u0440\u0430\u043d\u0435\u043d\u0438\u0435\u043c \u0431\u0430\u0440\u044c\u0435\u0440\u043e\u0432 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438 \u0432 \u043f\u0440\u0435\u0434\u0435\u043b\u0430\u0445 \u043d\u0430\u0448\u0435\u0439 \u043a\u043e\u043c\u043f\u0435\u0442\u0435\u043d\u0446\u0438\u0438.\u003C/p\u003E\n\u003Ch2\u003E\u041e\u0431\u0440\u0430\u0442\u043d\u0430\u044f \u0441\u0432\u044f\u0437\u044c \u0438 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u044b\u003C/h2\u003E\n\u003Cp\u003E\u0415\u0441\u043b\u0438 \u0432\u044b \u0438\u0441\u043f\u044b\u0442\u044b\u0432\u0430\u0435\u0442\u0435 \u0442\u0440\u0443\u0434\u043d\u043e\u0441\u0442\u0438 \u0441 \u0434\u043e\u0441\u0442\u0443\u043f\u043e\u043c \u043a \u0441\u043e\u0434\u0435\u0440\u0436\u0438\u043c\u043e\u043c\u0443 \u044d\u0442\u043e\u0433\u043e \u0441\u0430\u0439\u0442\u0430 \u0438\u043b\u0438 \u0445\u043e\u0442\u0438\u0442\u0435 \u0441\u043e\u043e\u0431\u0449\u0438\u0442\u044c \u043e \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0435 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438, \u0441\u0432\u044f\u0436\u0438\u0442\u0435\u0441\u044c \u0441 \u043d\u0430\u043c\u0438:\u003C/p\u003E\n\u003Cp\u003E\u042d\u043b. \u043f\u043e\u0447\u0442\u0430: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003E\u041f\u0440\u0438 \u043e\u0431\u0440\u0430\u0449\u0435\u043d\u0438\u0438, \u043f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u0443\u043a\u0430\u0436\u0438\u0442\u0435 URL \u043a\u043e\u043d\u043a\u0440\u0435\u0442\u043d\u043e\u0439 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u044b \u0438 \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u044b, \u0447\u0442\u043e\u0431\u044b \u043c\u044b \u043c\u043e\u0433\u043b\u0438 \u043f\u0440\u043e\u0432\u0435\u0441\u0442\u0438 \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0443 \u0438 \u043d\u0430\u0434\u043b\u0435\u0436\u0430\u0449\u0438\u043c \u043e\u0431\u0440\u0430\u0437\u043e\u043c \u043e\u0442\u0432\u0435\u0442\u0438\u0442\u044c.\u003C/p\u003E\n\u003Ch2\u003E\u041d\u0435\u043f\u0440\u0435\u0440\u044b\u0432\u043d\u043e\u0435 \u0441\u043e\u0432\u0435\u0440\u0448\u0435\u043d\u0441\u0442\u0432\u043e\u0432\u0430\u043d\u0438\u0435\u003C/h2\u003E\n\u003Cp\u003E\u041e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u0435 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438 \u2014 \u043d\u0435\u043f\u0440\u0435\u0440\u044b\u0432\u043d\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430. \u041c\u044b \u0440\u0435\u0433\u0443\u043b\u044f\u0440\u043d\u043e \u043f\u0435\u0440\u0435\u0441\u043c\u0430\u0442\u0440\u0438\u0432\u0430\u0435\u043c \u043d\u0430\u0448 \u0441\u0430\u0439\u0442 \u0438 \u043e\u0446\u0435\u043d\u0438\u0432\u0430\u0435\u043c \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u0438 \u0443\u043b\u0443\u0447\u0448\u0435\u043d\u0438\u044f \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438 \u0438 \u0443\u0434\u043e\u0431\u0441\u0442\u0432\u0430 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u044f.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003E\u0414\u0430\u0442\u0430 \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0435\u0433\u043e \u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u044f: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"\u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u0435\u0442","partially-conformant":"\u0447\u0430\u0441\u0442\u0438\u0447\u043d\u043e \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u0435\u0442","non-conformant":"\u043d\u0435 \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u0435\u0442","not-assessed":"\u043d\u0435 \u043e\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043b\u044f\u043b\u0441\u044f \u0434\u043e\u0441\u0442\u0443\u043f"}},"tr":{"template":"\u003Ch2\u003EEri\u015filebilirli\u011fe Ba\u011fl\u0131l\u0131k\u003C/h2\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{company_name}}\u003C/strong\u003E, \u003Cstrong\u003E{{website_url}}\u003C/strong\u003E adresinin eri\u015filebilirli\u011fini ve kullan\u0131labilirli\u011fini t\u00fcm kullan\u0131c\u0131lar \u2014 engelli bireyler dahil \u2014 i\u00e7in iyile\u015ftirmeyi taahh\u00fct eder. Kapsay\u0131c\u0131 bir dijital deneyim sunmay\u0131 ama\u00e7l\u0131yor ve web sitemiz genelinde eri\u015filebilirli\u011fi geli\u015ftirmek i\u00e7in s\u00fcrekli \u00e7al\u0131\u015f\u0131yoruz.\u003C/p\u003E\n\u003Ch2\u003EHedeflenen Eri\u015filebilirlik Standard\u0131\u003C/h2\u003E\n\u003Cp\u003EWeb sitemizi \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E eri\u015filebilirlik standard\u0131yla uyumlu hale getirmeyi hedefliyoruz.\u003C/p\u003E\n\u003Cp\u003EBu hedef standart, eri\u015filebilirli\u011fe y\u00f6nelik \u00e7abalar\u0131m\u0131za ve s\u00fcregelen iyile\u015ftirmelerimize y\u00f6n verir.\u003C/p\u003E\n\u003Ch2\u003EMevcut Uygunluk Durumu\u003C/h2\u003E\n\u003Cp\u003EDahili incelememize dayanarak bu web sitesi, \u003Cstrong\u003E{{accessibility_standard}}\u003C/strong\u003E bak\u0131m\u0131ndan \u003Cstrong\u003E{{conformance_status}}\u003C/strong\u003E durumundad\u0131r.\u003C/p\u003E\n\u003Cp\u003EBu durum, yay\u0131mlanma an\u0131ndaki de\u011ferlendirmemizi yans\u0131tmakta olup dahili incelememiz ve mevcut bilgilere dayanmaktad\u0131r. Eri\u015filebilirlik s\u00fcrekli bir s\u00fcre\u00e7tir; g\u00fcncellemeler hayata ge\u00e7irildik\u00e7e uygunluk d\u00fczeyleri de\u011fi\u015febilir.\u003C/p\u003E\n\u003Ch2\u003EEri\u015filebilirlik \u00d6zellikleri\u003C/h2\u003E\n\u003Cp\u003EEri\u015filebilirli\u011fi desteklemek amac\u0131yla bu web sitesinde AccessYes eri\u015filebilirlik aray\u00fcz\u00fc bulunmaktad\u0131r. Bu aray\u00fcz, kullan\u0131c\u0131lar\u0131n bireysel ihtiya\u00e7lar\u0131na g\u00f6re baz\u0131 g\u00f6rsel ve kullan\u0131m ayarlar\u0131n\u0131 de\u011fi\u015ftirmesine olanak tan\u0131r; \u00f6rne\u011fin:\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003EMetin boyutu ve aral\u0131k ayarlar\u0131\u003C/li\u003E\n\u003Cli\u003EKontrast ve renk ayarlar\u0131\u003C/li\u003E\n\u003Cli\u003EVurgulama ara\u00e7lar\u0131\u003C/li\u003E\n\u003Cli\u003EDi\u011fer destekleyici g\u00f6r\u00fcnt\u00fcleme se\u00e7enekleri\u003C/li\u003E\n\u003C/ul\u003E\n\u003Cp\u003EBu ara\u00e7lar, kullan\u0131c\u0131 deneyimini iyile\u015ftirmeyi ama\u00e7lar; ancak eri\u015filebilir i\u00e7erik ve do\u011fru altyap\u0131sal site yap\u0131s\u0131 gereklili\u011finin yerini alamaz.\u003C/p\u003E\n\u003Ch2\u003ES\u0131n\u0131rlamalar ve Teknik Hususlar\u003C/h2\u003E\n\u003Cp\u003EL\u00fctfen a\u015fa\u011f\u0131dakileri dikkate al\u0131n:\u003C/p\u003E\n\u003Cp\u003EEri\u015filebilirlik \u00f6zelliklerinin kullan\u0131labilirli\u011fi ve etkinli\u011fi, web sitesinin yap\u0131land\u0131rmas\u0131na ve s\u00fcrekli bak\u0131m\u0131na ba\u011fl\u0131d\u0131r.\u003C/p\u003E\n\u003Cp\u003E\u003Cstrong\u003E{{website_url}}\u003C/strong\u003E genelinde eri\u015filebilirli\u011fi sa\u011flamaya \u00e7al\u0131\u015fsak da, baz\u0131 i\u00e7erikler veya \u00f6zellikler se\u00e7ilen eri\u015filebilirlik standartlar\u0131n\u0131 hen\u00fcz tam olarak kar\u015f\u0131lamayabilir. Baz\u0131 i\u00e7erikler \u00fc\u00e7\u00fcnc\u00fc taraflarca sa\u011flanabilir veya do\u011frudan kontrol\u00fcm\u00fcz d\u0131\u015f\u0131ndaki teknik k\u0131s\u0131tlamalardan etkilenebilir.\u003C/p\u003E\n\u003Cp\u003EAyr\u0131ca, se\u00e7ilen eri\u015filebilirlik standard\u0131yla hen\u00fcz tam uyumlu olmayan eski i\u00e7erikler veya b\u00fct\u00fcnle\u015fmeler bulunabilir. Kontrol\u00fcm\u00fcz dahilindeki eri\u015filebilirlik engellerini belirlemek ve gidermek i\u00e7in aktif olarak \u00e7al\u0131\u015f\u0131yoruz.\u003C/p\u003E\n\u003Ch2\u003EGeri Bildirim ve \u0130leti\u015fim\u003C/h2\u003E\n\u003Cp\u003EBu sitedeki i\u00e7eri\u011fe eri\u015fimde zorluk ya\u015f\u0131yorsan\u0131z veya bir eri\u015filebilirlik sorununu bildirmek istiyorsan\u0131z l\u00fctfen bizimle ileti\u015fime ge\u00e7in:\u003C/p\u003E\n\u003Cp\u003EE&#8209;posta: \u003Ca href=\"mailto:{{contact_email}}\"\u003E\u003Cstrong\u003E{{contact_email}}\u003C/strong\u003E\u003C/a\u003E\u003C/p\u003E\n\u003Cp\u003E\u0130leti\u015fime ge\u00e7ti\u011finizde, l\u00fctfen ilgili sayfan\u0131n URL'sini ve sorunun a\u00e7\u0131klamas\u0131n\u0131 ekleyin ki durumu inceleyip uygun \u015fekilde yan\u0131t verebilelim.\u003C/p\u003E\n\u003Ch2\u003ES\u00fcrekli \u0130yile\u015ftirme\u003C/h2\u003E\n\u003Cp\u003EEri\u015filebilirlik s\u00fcrekli bir \u00e7abad\u0131r. Web sitemizi d\u00fczenli olarak g\u00f6zden ge\u00e7irir ve eri\u015filebilirli\u011fi ve kullan\u0131labilirli\u011fi geli\u015ftirme f\u0131rsatlar\u0131n\u0131 de\u011ferlendiririz.\u003C/p\u003E\n\u003Cp\u003E\u003Cem\u003ESon g\u00fcncelleme: {{last_updated}}\u003C/em\u003E\u003C/p\u003E","conformance_options":{"fully-conformant":"tam uyumlu","partially-conformant":"k\u0131smen uyumlu","non-conformant":"uyumlu de\u011fil","not-assessed":"eri\u015filmedi"}}};
